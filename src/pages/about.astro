---
import { aboutPageContent } from "../features/about/content";
import { externalLinks } from "../lib/site";
import SiteLayout from "../layouts/SiteLayout.astro";

const externalLinkMap = new Map(externalLinks.map((link) => [link.label, link.href]));
const aboutExternalLinks = aboutPageContent.externalLinks.flatMap((link) => {
  const href = externalLinkMap.get(link.label);

  if (!href) {
    return [];
  }

  return [{ ...link, href }];
});
const heroAvatarHref = externalLinkMap.get("X") ?? aboutPageContent.hero.avatar.href;
---

<SiteLayout title={aboutPageContent.title} description={aboutPageContent.description}>
  <section class="page-hero about-main">
    <p class="eyebrow">{aboutPageContent.hero.eyebrow}</p>
    <h1>{aboutPageContent.hero.title}</h1>
    <a
      href={heroAvatarHref}
      target="_blank"
      rel="noreferrer"
      aria-label="X を開く"
      class="avatar-link"
      style="width: clamp(7rem, 14vw, 11rem); height: clamp(7rem, 14vw, 11rem);"
    >
      <img src={aboutPageContent.hero.avatar.src} alt={aboutPageContent.hero.avatar.alt} class="avatar" loading="eager" />
    </a>
    <section class="about-section">
      <h2>{aboutPageContent.whatIDo.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.whatIDo.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </section>
    <section class="about-section">
      <h2>{aboutPageContent.domainsAndInterests.heading}</h2>
      <ul class="interest-list">
        {aboutPageContent.domainsAndInterests.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="about-section">
      <h2>{aboutPageContent.siteGuide.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.siteGuide.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <ul class="section-link-list">
        {aboutPageContent.siteGuide.items.map((item) => (
          <li class="section-link-item">
            <a href={item.href}>{item.label}</a>
            <p>{item.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </section>

  <section class="content-grid section-grid">
    <section class="content-panel">
      <h2>{aboutPageContent.externalLinksHeading}</h2>
      <ul class="link-list">
        {aboutExternalLinks.map((link) => (
          <li class="link-list-item">
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            <p>{link.description}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="content-panel">
      <h2>{aboutPageContent.contact.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.contact.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <a href={aboutPageContent.contact.href} class="button-link">{aboutPageContent.contact.ctaLabel}</a>
    </section>
  </section>
</SiteLayout>

<style>
  .eyebrow {
    margin: 0 0 0.4rem;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  h1,
  h2 {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0;
    font-size: clamp(1.55rem, 1.25rem + 1vw, 2.35rem);
  }

  h2 {
    margin-bottom: 0.65rem;
  }

  .about-main {
    display: grid;
    gap: 0.75rem;
  }

  .avatar-link {
    display: block;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: rgba(255, 255, 255, 0.5);
  }

  .avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .about-section {
    display: grid;
    gap: 0.55rem;
  }

  .about-section h2 {
    margin-bottom: 0;
  }

  .about-main p,
  .content-panel p {
    margin: 0;
  }

  .about-main .content-grid,
  .content-panel .content-grid {
    gap: 0.55rem;
  }

  .section-grid {
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
  }

  .link-list {
    display: grid;
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .link-list-item {
    display: grid;
    gap: 0.2rem;
  }

  .link-list-item p {
    color: var(--muted-color);
  }

  .interest-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.2rem;
  }

  .section-link-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .section-link-item {
    display: grid;
    gap: 0.2rem;
  }

  .section-link-item p {
    color: var(--muted-color);
  }

  .button-link {
    margin-top: 1rem;
  }
</style>
