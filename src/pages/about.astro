---
import PageHeader from "../components/PageHeader.astro";
import DescribedLinkList from "../features/about/DescribedLinkList.astro";
import { aboutPageContent } from "../features/about/content";
import { getExternalLink } from "../lib/site";
import SiteLayout from "../layouts/SiteLayout.astro";

const aboutExternalLinks = aboutPageContent.externalLinks.map((link) => {
  const externalLink = getExternalLink(link.id);
  return { ...link, href: externalLink.href, label: externalLink.label };
});
const profilePrimaryExternalLink = getExternalLink(aboutPageContent.profile.primaryExternalLinkId);
---

<SiteLayout title={aboutPageContent.title} description={aboutPageContent.description}>
  <PageHeader title={aboutPageContent.hero.title} eyebrow={aboutPageContent.hero.eyebrow} />

  <section class="content-panel about-main">
    <div class="profile-intro">
      <a
        href={profilePrimaryExternalLink.href}
        target="_blank"
        rel="noreferrer"
        aria-label={`${profilePrimaryExternalLink.label} を開く`}
        class="avatar-link"
      >
        <img src={aboutPageContent.profile.avatar.src} alt={aboutPageContent.profile.avatar.alt} class="avatar" loading="eager" />
      </a>
      <div class="profile-copy">
        <p class="profile-name">{aboutPageContent.profile.name}</p>
        <p>{aboutPageContent.profile.summary}</p>
      </div>
    </div>

    <section class="about-section">
      <h2>{aboutPageContent.whatIDo.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.whatIDo.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>{aboutPageContent.domainsAndInterests.heading}</h2>
      <ul class="interest-list">
        {aboutPageContent.domainsAndInterests.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="about-section">
      <h2>{aboutPageContent.siteGuide.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.siteGuide.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <DescribedLinkList items={aboutPageContent.siteGuide.items} />
    </section>
  </section>

  <section class="content-grid section-grid">
    <section class="content-panel">
      <h2>{aboutPageContent.externalLinksHeading}</h2>
      <DescribedLinkList items={aboutExternalLinks} />
    </section>

    <section class="content-panel">
      <h2>{aboutPageContent.contact.heading}</h2>
      <div class="content-grid">
        {aboutPageContent.contact.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <a href={aboutPageContent.contact.href} class="button-link">{aboutPageContent.contact.ctaLabel}</a>
    </section>
  </section>
</SiteLayout>

<style>
  h2 {
    margin-top: 0;
  }

  h2 {
    margin-bottom: 0.65rem;
  }

  .about-main {
    display: grid;
    gap: 1.1rem;
  }

  .profile-intro {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .profile-copy {
    display: grid;
    align-content: center;
    gap: 0.35rem;
  }

  .profile-name {
    margin: 0;
    font-size: clamp(1.3rem, 1.05rem + 1vw, 1.9rem);
    font-weight: 700;
    line-height: 1.25;
  }

  .avatar-link {
    display: block;
    width: clamp(6rem, 12vw, 9rem);
    height: clamp(6rem, 12vw, 9rem);
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: rgba(255, 255, 255, 0.5);
  }

  .avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .about-section {
    display: grid;
    gap: 0.55rem;
  }

  .about-section h2 {
    margin-bottom: 0;
  }

  .about-main p,
  .content-panel p {
    margin: 0;
  }

  .about-main .content-grid,
  .content-panel .content-grid {
    gap: 0.55rem;
  }

  .section-grid {
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
  }

  .interest-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.2rem;
  }

  .button-link {
    margin-top: 1rem;
  }

  @media (min-width: 720px) {
    .profile-intro {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }
</style>
