---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import GameActionPanel from "../../../components/GameActionPanel.astro";
import GameScreenshotGallery from "../../../components/GameScreenshotGallery.astro";
import { formatArticleNumericDate } from "../../../lib/article-dates";
import { getGamePlatformLabel, getGameStatusLabel, getGameTrailerEmbedUrl, type GameEntry } from "../../../lib/games";
import { formatPageBreadcrumb } from "../../../lib/page-header";
import SiteLayout from "../../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const games = await getCollection("games");

  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props as { game: GameEntry };
const statusLabel = getGameStatusLabel(game.data.status);
const trailerEmbedUrl = game.data.trailerUrl ? getGameTrailerEmbedUrl(game.data.trailerUrl) : null;
const hasActions = game.data.actions.length > 0;
const detailRows = [
  game.data.genre ? { label: "ジャンル", value: game.data.genre } : null,
  game.data.publishedAt ? { label: "公開日", value: formatArticleNumericDate(game.data.publishedAt) } : null,
  game.data.languages.length > 0 ? { label: "対応言語", value: game.data.languages.join(" / ") } : null,
  game.data.platforms.length > 0
    ? { label: "プラットフォーム", value: game.data.platforms.map((platform) => getGamePlatformLabel(platform)).join(" / ") }
    : null,
].filter((row): row is { label: string; value: string } => row !== null);
---

<SiteLayout title={game.data.title} description={game.data.description}>
  <article class="game-page">
    <p class="eyebrow game-page__eyebrow">{formatPageBreadcrumb("Home", "Games")}</p>

    <header class="game-hero">
      <div class="game-hero__cover">
        <Image src={game.data.cover} alt={game.data.coverAlt} widths={[1200, 960, 720]} sizes="(max-width: 56rem) 100vw, 56rem" />
      </div>
      <div class="game-hero__copy">
        <p class:list={["game-hero__status", `game-hero__status--${game.data.status}`]}>{statusLabel}</p>
        <h1>{game.data.title}</h1>
        <p class="game-hero__description">{game.data.description}</p>
      </div>
    </header>

    <div class:list={["game-detail-layout", hasActions && "game-detail-layout--with-actions"]}>
      <div class="game-detail-main">
        {game.data.features.length > 0 && (
          <section class="game-section content-panel" aria-label="ゲームの特徴">
            <ul class="game-feature-list">
              {game.data.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </section>
        )}

        <GameScreenshotGallery screenshots={game.data.screenshots} trailerEmbedUrl={trailerEmbedUrl} title={game.data.title} />
      </div>

      {hasActions && <GameActionPanel actions={game.data.actions} />}
    </div>

    {detailRows.length > 0 && (
      <section class="game-detail-table content-panel" aria-label="ゲームの基本情報">
        <table>
          <tbody>
            {detailRows.map((row) => (
              <tr>
                <th scope="row">{row.label}</th>
                <td>{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}
  </article>
</SiteLayout>

<style>
  .game-page {
    display: grid;
    gap: 1.5rem;
  }

  .game-page__eyebrow {
    margin-bottom: 0;
  }

  .game-hero {
    display: grid;
    gap: 1rem;
  }

  .game-hero__copy {
    display: grid;
    gap: 0.8rem;
  }

  .game-hero__copy h1,
  .game-hero__description,
  .game-hero__status {
    margin: 0;
  }

  .game-hero__status {
    width: fit-content;
    padding: 0.36rem 0.65rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .game-hero__status {
    border: 1px solid rgba(30, 27, 24, 0.1);
    background: rgba(30, 27, 24, 0.05);
  }

  .game-hero__status--active {
    border-color: rgba(14, 107, 99, 0.2);
    background: rgba(14, 107, 99, 0.1);
    color: var(--accent-color);
  }

  .game-hero__status--archived {
    border-color: rgba(217, 119, 6, 0.34);
    background: rgba(249, 115, 22, 0.2);
    color: #b45309;
  }

  .game-hero__status--prototype {
    border-color: rgba(168, 106, 0, 0.2);
    background: rgba(168, 106, 0, 0.1);
    color: #8b5600;
  }

  .game-hero__description {
    color: var(--muted-color);
    font-size: 1.02rem;
  }

  .game-hero__cover {
    width: min(100%, 46rem);
    justify-self: center;
    overflow: hidden;
    border-radius: 1.2rem;
    border: 1px solid var(--border-color);
    background: var(--surface-strong-color);
  }

  .game-hero__cover :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .game-detail-layout {
    display: grid;
    gap: 1.5rem;
  }

  .game-detail-main {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .game-section {
    display: grid;
    gap: 1rem;
  }

  .game-feature-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.2rem;
  }

  .game-detail-table {
    overflow-x: auto;
  }

  .game-detail-table table {
    min-width: min(100%, 28rem);
  }

  .game-detail-table th {
    width: 8.5rem;
    white-space: nowrap;
    color: var(--muted-color);
    font-weight: 500;
  }

  .game-detail-table td {
    color: var(--text-color);
  }

  @media (min-width: 960px) {
    .game-detail-layout--with-actions {
      grid-template-columns: minmax(0, 1fr) minmax(16rem, 18rem);
      align-items: start;
    }
  }
</style>
