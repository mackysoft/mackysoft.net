---
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout title="Treasure Rogue" description="Treasure Rogue の新しい導線です。">
  <section class="page-hero">
    <p class="eyebrow">Game</p>
    <h1>Treasure Rogue</h1>
    <p>旧ページ本文は移さず、作品情報を新しい構成へ載せ替える予定です。現時点では旧 URL の受け皿として維持しています。</p>
  </section>
</SiteLayout>

<style>
  .eyebrow {
    margin: 0 0 0.4rem;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  h1 {
    margin: 0 0 0.6rem;
  }
</style>
