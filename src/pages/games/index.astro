---
import PageIntro from "../../components/PageIntro.astro";
import PageHeader from "../../components/PageHeader.astro";
import { formatPageBreadcrumb } from "../../lib/page-header";
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout title="Games" description="ゲームの新しい一覧ページです。">
  <PageHeader title="Games" eyebrow={formatPageBreadcrumb("Home", "Games")} />

  <PageIntro panel>
    <p>旧サイトのゲーム紹介は引き継がず、新しい情報設計で再構成します。現時点では Treasure Rogue の導線だけを残しています。</p>
    <div class="button-row">
      <a href="/games/treasure-rogue/" class="button-link">Treasure Rogue</a>
    </div>
  </PageIntro>
</SiteLayout>
