---
import ArticleCard from "../components/ArticleCard.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import { getArticleItems, getLatestReleases } from "../lib/articles";
import SiteLayout from "../layouts/SiteLayout.astro";

const latestArticles = (await getArticleItems()).slice(0, 3);
const latestReleases = getLatestReleases();
---

<SiteLayout>
  <h1 class="visually-hidden">Home</h1>

  <section class="content-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Latest Articles</p>
        <h2>最新の記事</h2>
      </div>
      <a href="/articles/" class="button-link">Open Articles</a>
    </div>
    <div class="content-grid latest-articles-grid">
      {latestArticles.map((article) => (
        <ArticleCard article={article} layout="vertical" />
      ))}
    </div>
  </section>

  {latestReleases.length > 0 && (
    <section class="content-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Latest Releases</p>
          <h2>最新のリリース</h2>
        </div>
        <a href="https://github.com/mackysoft?tab=repositories" class="button-link" target="_blank" rel="noreferrer">
          Open GitHub
        </a>
      </div>
      <div class="content-grid latest-releases-grid">
        {latestReleases.map((release) => (
          <ReleaseCard release={release} />
        ))}
      </div>
    </section>
  )}

  <section class="content-grid feature-grid">
    <section class="content-panel">
      <p class="eyebrow">About</p>
      <h2>活動の正本をここに集約する</h2>
      <p>外部サービスに依存しすぎず、プロフィール、作品、記事、連絡導線を一か所で追える構成に切り替えています。</p>
      <a href="/about/" class="button-link">About</a>
    </section>
    <section class="content-panel">
      <p class="eyebrow">Contact</p>
      <h2>連絡手段の整理</h2>
      <p>仕事や相談向けの案内は新しい構成に合わせて更新中です。暫定の導線は Contact にまとめています。</p>
      <a href="/contact/" class="button-link">Contact</a>
    </section>
  </section>
</SiteLayout>

<style>
  h2 {
    margin: 0;
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
  }

  .section-head {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: end;
    margin-bottom: 1rem;
  }

  .feature-grid {
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }

  .latest-articles-grid {
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }

  .latest-releases-grid {
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
</style>
