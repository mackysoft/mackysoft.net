---
import { getHomePageTitle, homePageContent } from "../features/home/content";

const title = getHomePageTitle();
const { statusMessage } = homePageContent;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>{statusMessage}</p>
    </main>
  </body>
</html>
