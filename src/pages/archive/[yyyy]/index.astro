---
import ArticleCard from "../../../components/ArticleCard.astro";
import type { WritingItem } from "../../../lib/articles";
import { getLocalArticles, toLocalWritingItem } from "../../../lib/articles";
import SiteLayout from "../../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const articles = await getLocalArticles();
  const years = new Set(articles.map((article) => String(article.data.publishedAt.getFullYear())));

  return Array.from(years).sort().map((year) => ({
    params: { yyyy: year },
    props: {
      year,
      articles: articles
        .filter((article) => String(article.data.publishedAt.getFullYear()) === year)
        .map(toLocalWritingItem),
    },
  }));
}

const { year, articles } = Astro.props as { year: string; articles: WritingItem[] };
---

<SiteLayout title={`Archive ${year}`} description={`${year} 年の記事一覧です。`}>
  <section class="page-hero">
    <p class="eyebrow">Archive</p>
    <h1>{year}</h1>
    <p>{articles.length} 件の記事があります。</p>
  </section>

  <section class="content-grid">
    {articles.map((article) => (
      <ArticleCard article={article} />
    ))}
  </section>
</SiteLayout>

<style>
  .eyebrow {
    margin: 0 0 0.4rem;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  h1 {
    margin: 0 0 0.6rem;
  }
</style>
