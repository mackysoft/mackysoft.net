---
import ArticleCard from "../../../components/ArticleCard.astro";
import PageLead from "../../../components/PageLead.astro";
import PageHeader from "../../../components/PageHeader.astro";
import type { ArticleItem } from "../../../lib/articles";
import { getLocalArticles, toLocalArticleItem } from "../../../lib/articles";
import { formatPageBreadcrumb } from "../../../lib/page-header";
import SiteLayout from "../../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const articles = await getLocalArticles();
  const years = new Set(articles.map((article) => String(article.data.publishedAt.getFullYear())));

  return Array.from(years).sort().map((year) => ({
    params: { yyyy: year },
    props: {
      year,
      articles: articles
        .filter((article) => String(article.data.publishedAt.getFullYear()) === year)
        .map(toLocalArticleItem),
    },
  }));
}

const { year, articles } = Astro.props as { year: string; articles: ArticleItem[] };
---

<SiteLayout title={`Archive ${year}`} description={`${year} 年の記事一覧です。`}>
  <PageHeader title={year} eyebrow={formatPageBreadcrumb("Home", "Articles", "Archive")} />

  <PageLead summary={`${articles.length} 件の記事があります。`}>
    {articles.map((article) => (
      <ArticleCard article={article} />
    ))}
  </PageLead>
</SiteLayout>
