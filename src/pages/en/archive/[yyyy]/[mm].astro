---
import ArchiveMonthRoute, { getStaticPaths as getArchiveMonthStaticPaths } from "../../../../routes/archive/[yyyy]/[mm].astro";
import { getLocalArticles } from "../../../../lib/articles";

export const getStaticPaths = getArchiveMonthStaticPaths;

const { year, month, articleEntries } = Astro.props as {
  year: string;
  month: string;
  articleEntries: Awaited<ReturnType<typeof getLocalArticles>>;
};
---

<ArchiveMonthRoute year={year} month={month} articleEntries={articleEntries} locale="en" />
