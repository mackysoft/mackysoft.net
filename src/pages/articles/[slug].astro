---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

import PageHeader from "../../components/PageHeader.astro";
import type { ArticleEntry } from "../../lib/articles";
import { formatDate } from "../../lib/articles";
import { formatPageBreadcrumb } from "../../lib/page-header";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props as { article: ArticleEntry };
const { Content } = await render(article);
---

<SiteLayout title={article.data.title} description={article.data.description}>
  <article class="article-page">
    <PageHeader
      as="header"
      title={article.data.title}
      eyebrow={formatPageBreadcrumb("Home", "Articles")}
      class="article-hero"
    >
      <p class="lede">{article.data.description}</p>
      <p class="meta">
        <span>公開日: {formatDate(article.data.publishedAt)}</span>
        {article.data.updatedAt && <span>更新日: {formatDate(article.data.updatedAt)}</span>}
      </p>
      {article.data.tags.length > 0 && (
        <ul class="tags" aria-label="Article tags">
          {article.data.tags.map((tag) => (
            <li><a href={`/tags/${tag}/`}>{tag}</a></li>
          ))}
        </ul>
      )}
      {article.data.cover && (
        <div class="cover">
          <Image src={article.data.cover} alt={article.data.coverAlt ?? ""} widths={[1200, 720]} sizes="(max-width: 960px) 100vw, 60rem" />
        </div>
      )}
    </PageHeader>

    <section class="content-panel prose">
      <Content />
    </section>
  </article>
</SiteLayout>

<style>
  .article-page {
    display: grid;
    gap: 1.5rem;
  }

  :global(.article-hero h1) {
    margin: 0;
    font-size: clamp(2rem, 1.5rem + 2vw, 3.4rem);
  }

  .lede,
  .meta {
    margin: 0;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    color: var(--muted-color);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tags a {
    display: inline-flex;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--muted-color);
    text-decoration: none;
  }

  .cover {
    overflow: hidden;
    border-radius: 1.1rem;
  }

  .cover :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .prose {
    display: grid;
    gap: 1rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(table),
  .prose :global(pre),
  .prose :global(blockquote) {
    margin-top: 0;
    margin-bottom: 0;
  }

  .prose :global(hr) {
    width: 100%;
    border: 0;
    border-top: 1px solid var(--border-color);
  }
</style>
