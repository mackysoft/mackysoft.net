---
import ArticleCard from "../../components/ArticleCard.astro";
import PageCollection from "../../components/PageCollection.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getArticleItems } from "../../lib/articles";
import { formatPageBreadcrumb } from "../../lib/page-header";
import SiteLayout from "../../layouts/SiteLayout.astro";

const articleItems = await getArticleItems();
---

<SiteLayout title="Articles" description="自サイトと Zenn に公開した記事一覧です。">
  <PageHeader title="Articles" eyebrow={formatPageBreadcrumb("Home", "Articles")} />

  <PageCollection class="articles-list">
    {articleItems.map((article) => (
      <ArticleCard article={article} />
    ))}
  </PageCollection>
</SiteLayout>

<style>
  .articles-list {
    grid-template-columns: 1fr;
  }
</style>
