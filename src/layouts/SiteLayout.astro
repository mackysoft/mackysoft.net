---
import type { ImageMetadata } from "astro";

import { getDefaultSocialImage } from "../features/site/social-image";
import RootLocaleRedirect from "../components/head/RootLocaleRedirect.astro";
import SiteAnalytics from "../components/head/SiteAnalytics.astro";
import SiteSeo from "../components/head/SiteSeo.astro";
import ThemeBootstrap from "../components/head/ThemeBootstrap.astro";
import SiteHeaderOffsetSync from "../components/SiteHeaderOffsetSync.astro";
import SiteHeaderTools from "../components/SiteHeaderTools.astro";
import MobileNavMenu from "../components/header/MobileNavMenu.astro";
import PrimaryNav from "../components/header/PrimaryNav.astro";
import { getUiText } from "../lib/ui-text";
import { localizePath, stripLocaleFromPath, toLanguageTag, type SiteLocale } from "../lib/i18n";
import { externalLinks, getPrimaryNav, getSiteMeta } from "../lib/site";
import { buildSiteLayoutUrls } from "../lib/site-url.mjs";
import "../styles/site.css";

type AlternateLocaleLink = {
  locale: SiteLocale;
  path: string;
};

type AlternateLocaleUrl = AlternateLocaleLink & {
  href: string;
};

type Props = {
  title?: string;
  description?: string;
  locale?: SiteLocale;
  contentLocale?: SiteLocale;
  canonicalPath?: string;
  robotsContent?: string;
  alternateLocales?: AlternateLocaleLink[];
  isFallback?: boolean;
  enableLocaleRedirectOnRoot?: boolean;
  image?: ImageMetadata | string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  analyticsPageLocation?: string;
};

const {
  title,
  locale = "ja",
  contentLocale = locale,
  canonicalPath = Astro.url.pathname,
  robotsContent,
  alternateLocales = [],
  isFallback = false,
  enableLocaleRedirectOnRoot = false,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  analyticsPageLocation,
} = Astro.props as Props;
const siteMeta = getSiteMeta(locale);
const uiText = getUiText(locale);
const description = Astro.props.description ?? siteMeta.description;
const pageTitle = title ? `${title} | ${siteMeta.name}` : siteMeta.name;
const currentPath = Astro.url.pathname;
const primaryNav = getPrimaryNav(locale);
const siteUrl = Astro.url;
const { canonicalUrl, rssFeedUrl, alternateLocaleUrls } = buildSiteLayoutUrls(siteUrl, {
  canonicalPath,
  alternateLocales,
}) as {
  canonicalUrl: string;
  rssFeedUrl: string;
  alternateLocaleUrls: AlternateLocaleUrl[];
};
const enableSearchPanel = stripLocaleFromPath(currentPath) !== "/search/" && !(isFallback && locale !== contentLocale);
const footerColumns = [
  {
    heading: uiText.footer.linksHeading,
    links: [...externalLinks.map((link) => ({ ...link, isExternal: true }))],
  },
  {
    heading: uiText.footer.legalHeading,
    links: [{ href: localizePath("/privacy-policy/", locale), label: uiText.common.privacyPolicy, isExternal: false }],
  },
] as const;
const defaultSocialImage = getDefaultSocialImage(locale);
const socialImage = image ?? defaultSocialImage.src;
const socialImageAlt = imageAlt ?? defaultSocialImage.alt;
const socialImageWidth = imageWidth ?? (typeof image === "object" ? image.width : undefined) ?? defaultSocialImage.width;
const socialImageHeight = imageHeight ?? (typeof image === "object" ? image.height : undefined) ?? defaultSocialImage.height;
---

<!doctype html>
<html lang={toLanguageTag(isFallback ? contentLocale : locale)} data-theme="light" data-ui-locale={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <SiteSeo
      title={pageTitle}
      description={description}
      siteName={siteMeta.name}
      canonicalUrl={canonicalUrl}
      robotsContent={robotsContent}
      rssFeedUrl={rssFeedUrl}
      rssFeedTitle={`${siteMeta.name} - ${uiText.common.rssFeed}`}
      alternateLocaleUrls={alternateLocaleUrls}
      image={new URL(typeof socialImage === "string" ? socialImage : socialImage.src, siteUrl).toString()}
      imageAlt={socialImageAlt}
      imageWidth={socialImageWidth}
      imageHeight={socialImageHeight}
    />
    <ThemeBootstrap />
    <RootLocaleRedirect enabled={enableLocaleRedirectOnRoot} />
    <SiteAnalytics pageLocation={analyticsPageLocation} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&family=Roboto+Mono:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <header class="site-header" data-site-header>
      <div class="site-header__inner">
        <a href={localizePath("/", locale)} class="site-brand">{siteMeta.name}</a>
        <div class="site-header__nav">
          <PrimaryNav items={primaryNav} currentPath={currentPath} ariaLabel={uiText.header.primaryNavLabel} />
        </div>
        <SiteHeaderTools
          locale={locale}
          contentLocale={contentLocale}
          isFallback={isFallback}
          currentPath={currentPath}
          enableSearchPanel={enableSearchPanel}
        />
        <MobileNavMenu
          items={primaryNav}
          currentPath={currentPath}
          ariaLabel={uiText.header.primaryNavLabel}
          toggleLabel={uiText.header.menuToggle}
        />
      </div>
    </header>
    <div class="shell">
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <div class="site-footer__columns">
            {footerColumns.map((column) => (
              <section class="site-footer__column" aria-label={column.heading}>
                <p class="site-footer__heading">{column.heading}</p>
                <ul class="site-footer__link-list">
                  {column.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        target={link.isExternal ? "_blank" : undefined}
                        rel={link.isExternal ? "noreferrer" : undefined}
                        data-analytics-event={link.isExternal ? "external_link_click" : undefined}
                        data-analytics-label={link.isExternal ? link.label : undefined}
                        data-analytics-location={link.isExternal ? "site-footer" : undefined}
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
          <a href="/feed.xml" class="site-footer__rss-link" aria-label={uiText.common.rssFeed} title={uiText.common.rssFeed}>
            <svg class="site-footer__rss-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <circle cx="6" cy="18" r="1.7" fill="currentColor"></circle>
              <path d="M4.5 11.5a8 8 0 0 1 8 8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
              <path d="M4.5 5.5c7.73 0 14 6.27 14 14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
            </svg>
          </a>
        </div>
      </footer>
    </div>
    <SiteHeaderOffsetSync />
    <script>
      import { initSiteHeader } from "../scripts/site-header";

      initSiteHeader();
    </script>
  </body>
</html>
