---
import SiteHeaderOffsetSync from "../components/SiteHeaderOffsetSync.astro";
import SiteHeaderTools from "../components/SiteHeaderTools.astro";
import { getUiText } from "../lib/copy";
import { toLanguageTag, type SiteLocale } from "../lib/i18n";
import { externalLinks, getPrimaryNav, getSiteMeta } from "../lib/site";
import "../styles/site.css";

type AlternateLocaleLink = {
  locale: SiteLocale;
  path: string;
};

type Props = {
  title?: string;
  description?: string;
  locale?: SiteLocale;
  contentLocale?: SiteLocale;
  canonicalPath?: string;
  alternateLocales?: AlternateLocaleLink[];
  isFallback?: boolean;
  enableLocaleRedirectOnRoot?: boolean;
};

const {
  title,
  locale = "ja",
  contentLocale = locale,
  canonicalPath = Astro.url.pathname,
  alternateLocales = [],
  isFallback = false,
  enableLocaleRedirectOnRoot = false,
} = Astro.props as Props;
const siteMeta = getSiteMeta(locale);
const uiText = getUiText(locale);
const description = Astro.props.description ?? siteMeta.description;
const pageTitle = title ? `${title} | ${siteMeta.name}` : siteMeta.name;
const currentPath = Astro.url.pathname;
const primaryNav = getPrimaryNav(locale);
const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const alternateLocaleUrls = alternateLocales.map((entry) => ({
  ...entry,
  href: new URL(entry.path, Astro.site ?? Astro.url).toString(),
}));

function isCurrentNavItem(itemHref: string, path: string) {
  if (itemHref === "/") {
    return path === "/";
  }

  return path === itemHref || path.startsWith(itemHref);
}
---

<!doctype html>
<html lang={toLanguageTag(isFallback ? contentLocale : locale)} data-theme="light" data-ui-locale={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLocaleUrls.map((entry) => (
      <link rel="alternate" hreflang={toLanguageTag(entry.locale)} href={entry.href} />
    ))}
    <script is:inline>
      (() => {
        const storageKey = "mackysoft-theme";
        const root = document.documentElement;
        const darkQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const isValidTheme = (value) => value === "light" || value === "dark";
        const readStoredTheme = () => {
          try {
            const value = window.localStorage.getItem(storageKey);
            return isValidTheme(value) ? value : null;
          } catch {
            return null;
          }
        };
        const nextTheme = readStoredTheme() ?? (darkQuery.matches ? "dark" : "light");

        root.dataset.theme = nextTheme;
        root.style.colorScheme = nextTheme;
      })();
    </script>
    {
      enableLocaleRedirectOnRoot && (
        <script is:inline>
          (() => {
            const storageKey = "mackysoft-locale";
            const currentPath = window.location.pathname;
            const navigationEntry = performance.getEntriesByType("navigation")[0];

            if (currentPath !== "/") {
              return;
            }

            if (navigationEntry && "type" in navigationEntry && navigationEntry.type === "back_forward") {
              return;
            }

            const getPreferredLocale = () => {
              try {
                const storedLocale = window.localStorage.getItem(storageKey);

                if (storedLocale === "ja" || storedLocale === "en") {
                  return storedLocale;
                }
              } catch {
                // Ignore storage failures and fall back to browser languages.
              }

              for (const candidate of navigator.languages ?? [navigator.language]) {
                const normalizedCandidate = candidate.toLowerCase();

                if (normalizedCandidate === "en" || normalizedCandidate.startsWith("en-")) {
                  return "en";
                }

                if (normalizedCandidate === "ja" || normalizedCandidate.startsWith("ja-")) {
                  return "ja";
                }
              }

              return "ja";
            };

            if (getPreferredLocale() === "en") {
              window.location.replace("/en/");
            }
          })();
        </script>
      )
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&family=Roboto+Mono:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <header class="site-header" data-site-header>
      <div class="site-header__inner">
        <a href={locale === "en" ? "/en/" : "/"} class="site-brand">{siteMeta.name}</a>
        <nav class="site-header__nav" aria-label="Global">
          <ul class="site-nav">
            {primaryNav.map((item) => (
              <li>
                <a href={item.href} aria-current={isCurrentNavItem(item.href, currentPath) ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <SiteHeaderTools locale={locale} contentLocale={contentLocale} isFallback={isFallback} currentPath={currentPath} />
      </div>
    </header>
    <div class="shell">
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <ul class="footer-links">
          {externalLinks.map((link) => (
            <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
          <li><a href={locale === "en" ? "/en/privacy-policy/" : "/privacy-policy/"}>{uiText.common.privacyPolicy}</a></li>
        </ul>
      </footer>
    </div>
    <SiteHeaderOffsetSync />
  </body>
</html>
