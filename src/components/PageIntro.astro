---
type Props = {
  as?: "section" | "div";
  class?: string;
  panel?: boolean;
};

const { as = "section", class: className, panel = false } = Astro.props as Props;
const Tag = as;
const classes = ["page-intro", panel && "content-panel", className].filter(Boolean).join(" ");
---

<Tag class={classes}>
  <slot />
</Tag>

<style>
  .page-intro {
    display: grid;
    gap: 1rem;
  }

  .page-intro > :where(p, ul, ol) {
    margin: 0;
  }

  .page-intro > :last-child {
    margin-bottom: 0;
  }
</style>
