---
import { getUiText } from "../lib/ui-text";
import type { SiteLocale } from "../lib/i18n";

type TocHeading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: TocHeading[];
  locale?: SiteLocale;
};

const { headings, locale = "ja" } = Astro.props as Props;
const uiText = getUiText(locale);
---

<aside class="article-toc sticky-panel" aria-labelledby="article-toc-title">
  <div class="article-toc__inner content-panel">
    <h2 id="article-toc-title" class="article-toc__title">{uiText.article.tocTitle}</h2>
    <nav aria-label={uiText.article.tocNavLabel}>
      <ol class="article-toc__list">
        {headings.map((heading) => (
          <li class:list={["article-toc__item", heading.depth > 2 && "article-toc__item--nested"]}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  </div>
</aside>

<style>
  .article-toc {
    align-self: start;
  }

  .article-toc__inner {
    display: grid;
    gap: 0.8rem;
  }

  .article-toc__title {
    margin: 0;
    font-size: 1rem;
  }

  .article-toc__list {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-toc__item {
    margin: 0;
    padding: 0;
  }

  .article-toc__item a {
    color: var(--muted-color);
    text-decoration: none;
    line-height: 1.45;
  }

  .article-toc__item--nested {
    padding-left: 0.9rem;
    border-left: 1px solid var(--border-color);
  }
</style>
