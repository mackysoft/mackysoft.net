---
type Props = {
  as?: "section" | "div";
  class?: string;
  summary?: string;
};

const { as = "section", class: className, summary } = Astro.props as Props;
const Tag = as;
const classes = ["page-collection", className].filter(Boolean).join(" ");
---

<Tag class={classes}>
  {summary && <p class="page-collection__summary">{summary}</p>}
  <slot />
</Tag>

<style>
  .page-collection {
    display: grid;
    gap: 1rem;
  }

  .page-collection__summary {
    margin: 0;
    color: var(--muted-color);
  }
</style>
