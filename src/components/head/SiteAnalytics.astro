---
import { getAnalyticsMeasurementId } from "../../lib/analytics";
import { localizePath, supportedLocales } from "../../lib/i18n";

type Props = {
  pageLocation?: string;
};

const { pageLocation } = Astro.props as Props;
const measurementId = getAnalyticsMeasurementId(import.meta.env.PUBLIC_GA4_MEASUREMENT_ID);
const analyticsScriptUrl = measurementId
  ? `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId)}`
  : null;
const searchPaths = supportedLocales.map((locale) => localizePath("/search/", locale));
const analyticsConfig = measurementId && analyticsScriptUrl
  ? {
      analyticsScriptUrl,
      measurementId,
      pageLocation: pageLocation ?? null,
      searchPaths,
    }
  : null;
---

{
  analyticsConfig && (
    <>
      <script is:inline id="site-analytics-config" type="application/json" set:html={JSON.stringify(analyticsConfig)}></script>
      <script>
        import { initSiteAnalytics } from "../../scripts/site-analytics-client";

        initSiteAnalytics();
      </script>
    </>
  )
}
