---
import { toLanguageTag, type SiteLocale } from "../../lib/i18n";

type AlternateLocaleLink = {
  locale: SiteLocale;
  href: string;
};

type Props = {
  title: string;
  description: string;
  siteName: string;
  canonicalUrl: string;
  alternateLocaleUrls?: AlternateLocaleLink[];
  rssFeedUrl?: string;
  rssFeedTitle?: string;
};

const { title, description, siteName, canonicalUrl, alternateLocaleUrls = [], rssFeedUrl, rssFeedTitle } = Astro.props as Props;
---

<link rel="canonical" href={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
{rssFeedUrl && <link rel="alternate" type="application/rss+xml" title={rssFeedTitle ?? siteName} href={rssFeedUrl} />}
{alternateLocaleUrls.map((entry) => (
  <link rel="alternate" hreflang={toLanguageTag(entry.locale)} href={entry.href} />
))}
