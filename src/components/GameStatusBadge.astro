---
import type { SiteLocale } from "../lib/i18n";
import { getGameStatusLabel } from "../lib/game-presentation";
import type { GameStatus } from "../lib/game-repository";

type Props = {
  status: GameStatus;
  size?: "card" | "hero";
  locale?: SiteLocale;
};

const { status, size = "card", locale = "ja" } = Astro.props as Props;
const label = getGameStatusLabel(status, locale);
---

<span class:list={["pill", "game-status-badge", `game-status-badge--${size}`, `game-status-badge--${status}`]}>{label}</span>

<style>
  .game-status-badge {
    --pill-border-color: var(--status-neutral-border-color);
    --pill-bg-color: var(--status-neutral-bg-color);
    --pill-text-color: var(--text-color);
  }

  .game-status-badge--card {
    --pill-font-size: 0.82rem;
  }

  .game-status-badge--hero {
    --pill-padding-y: 0.36rem;
    --pill-padding-x: 0.65rem;
    --pill-font-size: 0.8rem;
  }

  .game-status-badge--active {
    --pill-border-color: var(--accent-border-color);
    --pill-bg-color: var(--accent-surface-color);
    --pill-text-color: var(--accent-color);
  }

  .game-status-badge--archived {
    --pill-border-color: var(--status-archived-border-color);
    --pill-bg-color: var(--status-archived-bg-color);
    --pill-text-color: var(--status-archived-text-color);
  }

  .game-status-badge--prototype {
    --pill-border-color: var(--status-prototype-border-color);
    --pill-bg-color: var(--status-prototype-bg-color);
    --pill-text-color: var(--status-prototype-text-color);
  }
</style>
