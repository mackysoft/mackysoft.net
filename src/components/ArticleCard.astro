---
import { Image } from "astro:assets";

import { articleTitleCardImageHeight, articleTitleCardImageWidth } from "../features/site/social-image";
import { getUiText } from "../lib/ui-text";
import { defaultLocale, type SiteLocale } from "../lib/i18n";
import { formatContentDate } from "../lib/content-date";
import type { ArticleItem } from "../lib/articles";

type Props = {
  article: ArticleItem;
  layout?: "horizontal" | "vertical";
  locale?: SiteLocale;
};

const { article, layout = "horizontal", locale = "ja" } = Astro.props as Props;
const isExternal = article.kind === "external";
const cover = article.cover;
const isStringCover = typeof cover === "string";
const isPublicCover = isStringCover && cover.startsWith("/");
const isRemoteCover = isStringCover && !isPublicCover;
const localCover = isStringCover ? undefined : cover;
const showDescription = layout === "horizontal";
const coverWidth = typeof cover === "string" ? undefined : cover?.width;
const coverHeight = typeof cover === "string" ? undefined : cover?.height;
const coverAspectRatio = coverWidth && coverHeight ? `${coverWidth} / ${coverHeight}` : "1200 / 630";
const verticalCoverStyle = layout === "vertical" ? `--article-cover-ratio: ${coverAspectRatio};` : undefined;
const coverSizes = layout === "vertical" ? "(max-width: 720px) 100vw, 20rem" : "(max-width: 720px) 100vw, 28rem";
const publishedAtLabel = formatContentDate(article.publishedAt, locale);
const uiText = getUiText(locale);
---

<article class:list={["article-card", "activity-card", layout === "vertical" && "activity-card--compact", `article-card--${layout}`, !cover && "article-card--no-cover"]}>
  <a
    href={article.href}
    class="activity-card__link-layer"
    aria-label={article.title}
    target={isExternal ? "_blank" : undefined}
    rel={isExternal ? "noreferrer" : undefined}
    data-analytics-event={isExternal ? "external_link_click" : undefined}
    data-analytics-label={isExternal ? article.title : undefined}
    data-analytics-location={isExternal ? "article-card" : undefined}
  ></a>
  {cover ? (
    <div
      class="article-card__cover activity-card__cover"
      style={verticalCoverStyle}
    >
      {isPublicCover ? (
        <img
          src={cover}
          alt={article.coverAlt ?? ""}
          width={articleTitleCardImageWidth}
          height={articleTitleCardImageHeight}
          loading="lazy"
          decoding="async"
        />
      ) : isRemoteCover ? (
        <Image src={cover} alt={article.coverAlt ?? ""} widths={[480]} sizes={coverSizes} inferSize />
      ) : (
        <Image src={localCover!} alt={article.coverAlt ?? ""} widths={[480]} sizes={coverSizes} />
      )}
    </div>
  ) : (
    <div class="article-card__cover-placeholder" aria-hidden="true" style={verticalCoverStyle}></div>
  )}
  <div class="article-card__body activity-card__body">
    <h3 class="activity-card__title">{article.title}</h3>
    {article.isFallback && locale !== defaultLocale && (
      <div class="activity-card__badges">
        <span class="activity-card__badge">{uiText.common.japaneseOnlyBadge}</span>
      </div>
    )}
    {showDescription && <p class="article-card__description">{article.description}</p>}
    <p class="article-card__meta activity-card__meta">
      <span class="article-card__meta-date">
        <span class="article-card__meta-label">{uiText.article.publishedAt}</span>
        <span>{publishedAtLabel}</span>
      </span>
      <span>{article.source}</span>
    </p>
  </div>
</article>

  <style>
  .article-card {
    gap: 1rem;
    height: auto;
    padding: 1.25rem;
  }

  .article-card--vertical {
    align-content: stretch;
    height: auto;
    min-height: 0;
  }

  .article-card__cover-placeholder {
    display: none;
  }

  .article-card__body {
    gap: 0.85rem;
  }

  .article-card__meta-date {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .article-card__meta {
    font-size: 0.92rem;
  }

  .article-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .article-card__description {
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .article-card__meta {
    margin-top: auto;
  }

  .article-card--vertical .article-card__cover,
  .article-card--vertical .article-card__cover-placeholder {
    aspect-ratio: var(--article-cover-ratio, 1200 / 630);
  }

  .article-card--vertical .article-card__body {
    grid-template-rows: auto auto;
    align-content: start;
    gap: 0.4rem;
  }

  .article-card--vertical h3 {
    font-size: clamp(0.9rem, 0.87rem + 0.2vw, 0.98rem);
    line-height: 1.32;
    -webkit-line-clamp: 3;
  }

  .article-card--vertical .article-card__meta {
    font-size: 0.84rem;
    margin-top: 0;
  }

  @media (max-width: 759px) {
    .article-card {
      padding: 1rem;
    }

    .article-card__description {
      display: none;
    }
  }

  @media (min-width: 760px) {
    .article-card--horizontal {
      grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
      align-items: start;
      height: 15rem;
    }

    .article-card--horizontal .article-card__description {
      -webkit-line-clamp: 3;
    }

    .article-card--horizontal.article-card--no-cover .article-card__cover-placeholder {
      display: block;
    }
  }
</style>
