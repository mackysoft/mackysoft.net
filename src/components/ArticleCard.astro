---
import { Image } from "astro:assets";

import { formatArticleDate } from "../lib/article-dates";
import type { ArticleItem } from "../lib/articles";

type Props = {
  article: ArticleItem;
  layout?: "horizontal" | "vertical";
};

const { article, layout = "horizontal" } = Astro.props;
const isExternal = article.kind === "external";
const cover = article.cover;
const isRemoteCover = typeof cover === "string";
const showDescription = layout === "horizontal";
const coverWidth = typeof cover === "string" ? undefined : cover?.width;
const coverHeight = typeof cover === "string" ? undefined : cover?.height;
const coverAspectRatio = coverWidth && coverHeight ? `${coverWidth} / ${coverHeight}` : "1200 / 630";
const verticalCoverStyle = layout === "vertical" ? `--article-cover-ratio: ${coverAspectRatio};` : undefined;
const coverSizes = layout === "vertical" ? "(max-width: 720px) 100vw, 20rem" : "(max-width: 720px) 100vw, 28rem";
const publishedAtLabel = formatArticleDate(article.publishedAt);
---

<article class:list={["article-card", "activity-card", layout === "vertical" && "activity-card--compact", `article-card--${layout}`, !cover && "article-card--no-cover"]}>
  {cover ? (
    <a
      href={article.href}
      class="article-card__cover-link activity-card__cover-link"
      target={isExternal ? "_blank" : undefined}
      rel={isExternal ? "noreferrer" : undefined}
      style={verticalCoverStyle}
    >
      {isRemoteCover ? (
        <Image src={cover} alt={article.coverAlt ?? ""} widths={[480]} sizes={coverSizes} inferSize />
      ) : (
        <Image src={cover} alt={article.coverAlt ?? ""} widths={[480]} sizes={coverSizes} />
      )}
    </a>
  ) : (
    <div class="article-card__cover-placeholder" aria-hidden="true" style={verticalCoverStyle}></div>
  )}
  <div class="article-card__body activity-card__body">
    <h3>
      <a
        href={article.href}
        class="activity-card__title-link"
        target={isExternal ? "_blank" : undefined}
        rel={isExternal ? "noreferrer" : undefined}
      >
        {article.title}
      </a>
    </h3>
    {showDescription && <p class="article-card__description">{article.description}</p>}
    <p class="article-card__meta activity-card__meta">
      <span class="article-card__meta-date">
        <span class="article-card__meta-label">公開日</span>
        <span>{publishedAtLabel}</span>
      </span>
      <span>{article.source}</span>
    </p>
  </div>
</article>

  <style>
  .article-card {
    gap: 1rem;
    height: clamp(19rem, 18rem + 4vw, 22rem);
    padding: 1.25rem;
  }

  .article-card--vertical {
    align-content: stretch;
    height: 19.75rem;
  }

  .article-card__cover-placeholder {
    display: none;
  }

  .article-card__body {
    gap: 0.85rem;
  }

  .article-card__meta-date {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .article-card__meta {
    font-size: 0.92rem;
  }

  .article-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .article-card__description {
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .article-card__meta {
    margin-top: auto;
  }

  .article-card--vertical .article-card__cover-link,
  .article-card--vertical .article-card__cover-placeholder {
    aspect-ratio: var(--article-cover-ratio, 1200 / 630);
  }

  .article-card--vertical .article-card__body {
    grid-template-rows: auto auto;
    align-content: start;
    gap: 0.4rem;
  }

  .article-card--vertical h3 {
    font-size: clamp(0.9rem, 0.87rem + 0.2vw, 0.98rem);
    line-height: 1.32;
    -webkit-line-clamp: 3;
  }

  .article-card--vertical .article-card__meta {
    font-size: 0.84rem;
    margin-top: 0;
  }

  @media (min-width: 760px) {
    .article-card--horizontal {
      grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
      align-items: start;
      height: 15rem;
    }

    .article-card--horizontal .article-card__description {
      -webkit-line-clamp: 3;
    }

    .article-card--horizontal.article-card--no-cover .article-card__cover-placeholder {
      display: block;
    }
  }
</style>
