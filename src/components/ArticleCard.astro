---
import { Image } from "astro:assets";

import type { WritingItem } from "../lib/articles";
import { formatDate } from "../lib/articles";

type Props = {
  article: WritingItem;
};

const { article } = Astro.props;
const isExternal = article.kind === "external";
---

<article class="article-card">
  {article.cover && (
    <a href={article.href} class="article-card__cover-link">
      <Image src={article.cover} alt={article.coverAlt ?? ""} widths={[480]} sizes="(max-width: 720px) 100vw, 28rem" />
    </a>
  )}
  <div class="article-card__body">
    <p class="article-card__meta">
      <span>{formatDate(article.publishedAt)}</span>
      <span>{article.source}</span>
      {isExternal && <span>External</span>}
    </p>
    <h3>
      <a href={article.href} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined}>
        {article.title}
      </a>
    </h3>
    <p>{article.description}</p>
    {article.tags.length > 0 && (
      <ul class="article-card__tags" aria-label="Article tags">
        {article.tags.map((tag) => (
          <li><a href={`/tags/${tag}/`}>{tag}</a></li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .article-card {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 1.25rem;
    background: var(--surface-color);
  }

  .article-card__cover-link {
    display: block;
    overflow: hidden;
    border-radius: 0.9rem;
    background: var(--surface-strong-color);
  }

  .article-card__cover-link :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .article-card__body {
    display: grid;
    gap: 0.85rem;
  }

  .article-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
    color: var(--muted-color);
    font-size: 0.92rem;
  }

  .article-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
  }

  .article-card h3 a {
    color: var(--text-color);
    text-decoration: none;
  }

  .article-card p {
    margin: 0;
  }

  .article-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-card__tags a {
    display: inline-flex;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--muted-color);
    text-decoration: none;
    font-size: 0.88rem;
  }
</style>
