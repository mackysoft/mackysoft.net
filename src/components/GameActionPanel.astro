---
import { sortGameActions, type GameAction } from "../lib/games";

type Props = {
  actions: GameAction[];
};

const { actions } = Astro.props;
const sortedActions = sortGameActions(actions);
---

<aside class="game-action-panel" aria-label="外部リンク">
  <div class="game-action-panel__inner content-panel">
    {sortedActions.length > 0 ? (
      <div class="game-action-panel__actions">
        {sortedActions.map((action) => (
          <a href={action.href} class="button-link game-action-panel__button" target="_blank" rel="noreferrer">
            {action.label}
          </a>
        ))}
      </div>
    ) : (
      <p class="game-action-panel__empty">公開中の外部導線はありません。</p>
    )}
  </div>
</aside>

<style>
  .game-action-panel__inner {
    display: grid;
    gap: 1rem;
  }

  .game-action-panel__empty {
    margin: 0;
  }

  .game-action-panel__actions {
    display: grid;
    gap: 0.75rem;
  }

  .game-action-panel__button {
    width: 100%;
    justify-content: center;
    padding-block: 0.85rem;
    border-color: rgba(76, 175, 80, 0.38);
    background: #4caf50;
    color: #fffdf9;
    font-weight: 700;
    box-shadow: 0 0.9rem 1.9rem rgba(76, 175, 80, 0.24);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease;
  }

  .game-action-panel__button:hover,
  .game-action-panel__button:focus-visible {
    background: #449d48;
    color: #fffdf9;
    box-shadow: 0 0.95rem 2rem rgba(56, 142, 60, 0.28);
    transform: translateY(-1px);
  }

  .game-action-panel__empty {
    color: var(--muted-color);
  }

  @media (min-width: 960px) {
    .game-action-panel {
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
