---
import { isExternalGameActionHref, sortGameActions, type GameAction } from "../lib/games";

type Props = {
  actions: GameAction[];
};

const { actions } = Astro.props;
const sortedActions = sortGameActions(actions);
---

{
  sortedActions.length > 0 && (
    <aside class="game-action-panel sticky-panel" aria-label="リンク">
      <div class="game-action-panel__inner content-panel">
        <div class="game-action-panel__actions">
          {sortedActions.map((action) => (
            <a
              href={action.href}
              class="button-link game-action-panel__button"
              target={isExternalGameActionHref(action.href) ? "_blank" : undefined}
              rel={isExternalGameActionHref(action.href) ? "noreferrer" : undefined}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
    </aside>
  )
}

<style>
  .game-action-panel__inner {
    display: grid;
    gap: 1rem;
  }

  .game-action-panel__actions {
    display: grid;
    gap: 0.75rem;
  }

  .game-action-panel__button {
    width: 100%;
    justify-content: center;
    padding-block: 0.85rem;
    border-color: rgba(76, 175, 80, 0.38);
    background: #4caf50;
    color: #fffdf9;
    font-weight: 700;
    box-shadow: 0 0.9rem 1.9rem rgba(76, 175, 80, 0.24);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease;
  }

  .game-action-panel__button:hover,
  .game-action-panel__button:focus-visible {
    background: #449d48;
    color: #fffdf9;
    box-shadow: 0 0.95rem 2rem rgba(56, 142, 60, 0.28);
    transform: translateY(-1px);
  }
</style>
