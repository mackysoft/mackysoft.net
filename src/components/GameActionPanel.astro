---
import { getUiText } from "../lib/ui-text";
import type { SiteLocale } from "../lib/i18n";
import { sortGameActions } from "../lib/game-presentation";
import type { GameAction } from "../lib/game-repository";
import { isExternalHttpHref } from "../lib/safe-href";

type Props = {
  actions: GameAction[];
  locale?: SiteLocale;
};

const { actions, locale = "ja" } = Astro.props as Props;
const sortedActions = sortGameActions(actions);
const uiText = getUiText(locale);
---

{
  sortedActions.length > 0 && (
    <aside class="game-action-panel sticky-panel" aria-label={uiText.game.linksAriaLabel}>
      <div class="game-action-panel__inner content-panel">
        <div class="game-action-panel__actions">
          {sortedActions.map((action) => (
            <a
              href={action.href}
              class="button-link game-action-panel__button"
              target={isExternalHttpHref(action.href) ? "_blank" : undefined}
              rel={isExternalHttpHref(action.href) ? "noreferrer" : undefined}
              data-analytics-event={isExternalHttpHref(action.href) ? "external_link_click" : undefined}
              data-analytics-label={isExternalHttpHref(action.href) ? action.label : undefined}
              data-analytics-location={isExternalHttpHref(action.href) ? "game-action-panel" : undefined}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
    </aside>
  )
}

<style>
  .game-action-panel__inner {
    display: grid;
    gap: 1rem;
  }

  .game-action-panel__actions {
    display: grid;
    gap: 0.75rem;
  }

  .game-action-panel__button {
    width: 100%;
    justify-content: center;
    padding-block: 0.85rem;
    border-color: var(--action-button-border-color);
    background: var(--action-button-bg-color);
    color: var(--action-button-text-color);
    font-weight: 700;
    transition: background-color 160ms ease;
  }

  .game-action-panel__button:hover,
  .game-action-panel__button:focus-visible {
    background: var(--action-button-hover-bg-color);
    color: var(--action-button-text-color);
  }
</style>
