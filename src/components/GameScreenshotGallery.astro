---
import { Image } from "astro:assets";

import type { GameEntry } from "../lib/games";

type Props = {
  screenshots: GameEntry["data"]["screenshots"];
};

const { screenshots } = Astro.props;
---

{
  screenshots.length > 0 && (
    <section class="game-screenshot-gallery content-panel" aria-label="スクリーンショット">
      <div class="game-screenshot-gallery__grid">
        {screenshots.map((screenshot) => (
          <figure class="game-screenshot-gallery__item">
            <Image
              src={screenshot.image}
              alt={screenshot.alt}
              widths={[720, 540]}
              sizes="(max-width: 720px) 100vw, (max-width: 1080px) 50vw, 22rem"
            />
          </figure>
        ))}
      </div>
    </section>
  )
}

<style>
  .game-screenshot-gallery,
  .game-screenshot-gallery__grid,
  .game-screenshot-gallery__item {
    display: grid;
  }

  .game-screenshot-gallery {
    gap: 1rem;
  }

  .game-screenshot-gallery__item {
    margin: 0;
  }

  .game-screenshot-gallery__grid {
    gap: 1rem;
  }

  .game-screenshot-gallery__item {
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.4);
  }

  .game-screenshot-gallery__item :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 720px) {
    .game-screenshot-gallery__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
  }
</style>
