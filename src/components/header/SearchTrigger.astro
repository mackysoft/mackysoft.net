---
import { getUiText } from "../../lib/ui-text";
import type { SiteLocale } from "../../lib/i18n";

type Props = {
  locale: SiteLocale;
  href: string;
  enableInline?: boolean;
  panelId?: string;
};

const {
  locale,
  href,
  enableInline = true,
  panelId = "site-search-inline",
} = Astro.props as Props;
const uiText = getUiText(locale);
---

<a
  href={href}
  class="site-header-tool site-header-tool--icon"
  aria-label={uiText.header.searchOpen}
  aria-controls={enableInline ? panelId : undefined}
  aria-expanded={enableInline ? "false" : undefined}
  data-site-tool="search"
  data-site-search-trigger
  data-site-search-panel-id={enableInline ? panelId : undefined}
>
  <svg class="site-header-tool__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
    <path d="M16 16L21 21" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
  </svg>
</a>
