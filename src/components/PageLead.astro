---
type Props = {
  as?: "section" | "div";
  class?: string;
  panel?: boolean;
  summary?: string;
};

const { as = "section", class: className, panel = false, summary } = Astro.props as Props;
const Tag = as;
const classes = ["page-lead", panel && "content-panel", className].filter(Boolean).join(" ");
---

<Tag class={classes}>
  {summary && <p class="page-lead__summary">{summary}</p>}
  <slot />
</Tag>

<style>
  .page-lead {
    display: grid;
    gap: 1rem;
  }

  .page-lead__summary {
    margin: 0;
    color: var(--muted-color);
  }

  .page-lead > :where(p, ul, ol) {
    margin: 0;
  }

  .page-lead > :last-child {
    margin-bottom: 0;
  }
</style>
