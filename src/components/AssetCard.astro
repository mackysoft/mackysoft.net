---
import { getUiText } from "../lib/ui-text";
import type { SiteLocale } from "../lib/i18n";
import { formatContentDate } from "../lib/content-date";
import { formatReleaseStargazerCount, getReleaseRepoName, type ReleaseActivity } from "../lib/releases";

type Props = {
  release: ReleaseActivity;
  locale?: SiteLocale;
};

const { release, locale = "ja" } = Astro.props as Props;
const repoName = getReleaseRepoName(release.repo);
const stargazerCount = formatReleaseStargazerCount(release.stargazerCount, locale);
const uiText = getUiText(locale);
---

<article class="asset-card activity-card">
  <a
    href={release.url}
    class="activity-card__link-layer"
    aria-label={repoName}
    target="_blank"
    rel="noreferrer"
    data-analytics-event="external_link_click"
    data-analytics-label={repoName}
    data-analytics-location="asset-card"
  ></a>
  <div class="asset-card__cover activity-card__cover" data-cover-state="ready">
    <img
      src={release.coverUrl}
      alt={release.coverAlt}
      width={480}
      height={252}
      sizes="(max-width: 720px) 100vw, 28rem"
      loading="lazy"
      decoding="async"
      onerror="this.parentElement?.setAttribute('data-cover-state', 'error')"
    />
    <div class="asset-card__cover-fallback" aria-hidden="true">
      <span class="asset-card__cover-kicker">GitHub</span>
      <strong class="asset-card__cover-title">{repoName}</strong>
    </div>
  </div>
  <div class="asset-card__body activity-card__body">
    <h3 class="activity-card__title">{repoName}</h3>
    <div class="asset-card__copy">
      {release.description && <p class="asset-card__description">{release.description}</p>}
    </div>
    <div class="asset-card__footer">
      <p class="asset-card__meta activity-card__meta">
        <span class="asset-card__meta-date">
          <span class="asset-card__meta-label">{uiText.release.latestReleaseDate}</span>
          <span>{formatContentDate(new Date(release.publishedAt), locale)}</span>
        </span>
      </p>
      <div class="asset-card__metrics">
        {release.license && <p class="asset-card__license">{release.license}</p>}
        <p class="asset-card__version">{release.version}</p>
        <span class="asset-card__stars" aria-label={`GitHub stars ${stargazerCount}`}>
          <svg class="asset-card__star-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3.25 14.703 8.728l6.047.879-4.375 4.265 1.033 6.022L12 17.051l-5.408 2.843 1.033-6.022-4.375-4.265 6.047-.879L12 3.25Z" />
          </svg>
          <span class="asset-card__star-count">{stargazerCount}</span>
        </span>
      </div>
    </div>
  </div>
</article>

<style>
  .asset-card {
    gap: 1rem;
    padding: 1.25rem;
  }

  .asset-card__cover {
    aspect-ratio: 1200 / 630;
    position: relative;
    overflow: hidden;
  }

  .asset-card__cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .asset-card__cover-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: end;
    gap: 0.35rem;
    padding: 1rem;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent-color) 22%, transparent) 0, transparent 36%),
      linear-gradient(160deg, color-mix(in srgb, var(--surface-soft-color) 92%, white) 0%, var(--surface-color) 100%);
    color: var(--text-color);
  }

  .asset-card__cover[data-cover-state="ready"] .asset-card__cover-fallback {
    display: none;
  }

  .asset-card__cover[data-cover-state="error"] img {
    display: none;
  }

  .asset-card__cover-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-color);
  }

  .asset-card__cover-title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: clamp(1rem, 0.9rem + 0.45vw, 1.25rem);
    line-height: 1.2;
  }

  .asset-card__body {
    gap: 0.85rem;
  }

  .asset-card__copy,
  .asset-card__description,
  .asset-card__meta,
  .asset-card__meta-label,
  .asset-card__license,
  .asset-card__version,
  .asset-card__stars {
    margin: 0;
  }

  .asset-card__copy {
    min-height: 0;
  }

  .asset-card__meta-date {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .asset-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .asset-card__description {
    color: var(--muted-color);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .asset-card__footer {
    display: grid;
    gap: 0.5rem;
    margin-top: auto;
  }

  .asset-card__meta {
    font-size: 0.92rem;
  }

  .asset-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .asset-card__version {
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__license {
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--surface-soft-border-color);
    border-radius: 999px;
    background: var(--surface-soft-color);
    color: var(--muted-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__version {
    background: var(--accent-surface-color);
    color: var(--accent-color);
  }

  .asset-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--accent-border-color);
    border-radius: 999px;
    color: var(--text-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__star-icon {
    flex: none;
    width: 0.85rem;
    height: 0.85rem;
    fill: var(--warm-accent-color);
    opacity: 1;
  }

  .asset-card__star-count {
    line-height: 1;
  }

  @media (max-width: 759px) {
    .asset-card {
      padding: 1rem;
    }

    .asset-card__description {
      display: none;
    }
  }

  @media (min-width: 760px) {
    .asset-card {
      grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
