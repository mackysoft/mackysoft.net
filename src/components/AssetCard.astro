---
import { Image } from "astro:assets";

import { formatArticleDate } from "../lib/article-dates";
import { formatReleaseStargazerCount, getReleaseRepoName, type ReleaseActivity } from "../lib/articles";

type Props = {
  release: ReleaseActivity;
};

const { release } = Astro.props;
const repoName = getReleaseRepoName(release.repo);
const stargazerCount = formatReleaseStargazerCount(release.stargazerCount);
---

<article class="asset-card activity-card">
  <a href={release.url} class="asset-card__cover-link activity-card__cover-link" target="_blank" rel="noreferrer">
    <Image
      src={release.coverUrl}
      alt={release.coverAlt}
      widths={[480]}
      sizes="(max-width: 720px) 100vw, 28rem"
      inferSize
    />
  </a>
  <div class="asset-card__body activity-card__body">
    <h3>
      <a href={release.url} class="activity-card__title-link" target="_blank" rel="noreferrer">{repoName}</a>
    </h3>
    <div class="asset-card__copy">
      {release.description && <p class="asset-card__description">{release.description}</p>}
    </div>
    <div class="asset-card__footer">
      <p class="asset-card__meta activity-card__meta">
        <span class="asset-card__meta-label">{"Latest Release"}</span>
        <span>{formatArticleDate(new Date(release.publishedAt))}</span>
      </p>
      <div class="asset-card__metrics">
        {release.license && <p class="asset-card__license">{release.license}</p>}
        <p class="asset-card__version">{release.version}</p>
        <span class="asset-card__stars" aria-label={`GitHub stars ${stargazerCount}`}>
          <svg class="asset-card__star-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3.25 14.703 8.728l6.047.879-4.375 4.265 1.033 6.022L12 17.051l-5.408 2.843 1.033-6.022-4.375-4.265 6.047-.879L12 3.25Z" />
          </svg>
          <span class="asset-card__star-count">{stargazerCount}</span>
        </span>
      </div>
    </div>
  </div>
</article>

<style>
  .asset-card {
    gap: 1rem;
    padding: 1.25rem;
  }

  .asset-card__cover-link {
    aspect-ratio: 1200 / 630;
  }

  .asset-card__cover-link img {
    height: 100%;
    object-fit: cover;
  }

  .asset-card__body {
    gap: 0.85rem;
  }

  .asset-card__copy,
  .asset-card__description,
  .asset-card__meta,
  .asset-card__meta-label,
  .asset-card__license,
  .asset-card__version,
  .asset-card__stars {
    margin: 0;
  }

  .asset-card__copy {
    min-height: 0;
  }

  .asset-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .asset-card__description {
    color: var(--muted-color);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .asset-card__footer {
    display: grid;
    gap: 0.5rem;
    margin-top: auto;
  }

  .asset-card__meta {
    font-size: 0.92rem;
  }

  .asset-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .asset-card__version {
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__license {
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border: 1px solid rgba(30, 27, 24, 0.12);
    border-radius: 999px;
    background: rgba(30, 27, 24, 0.04);
    color: var(--muted-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__version {
    background: rgba(14, 107, 99, 0.1);
    color: var(--accent-color);
  }

  .asset-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border: 1px solid rgba(14, 107, 99, 0.16);
    border-radius: 999px;
    color: var(--text-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .asset-card__star-icon {
    flex: none;
    width: 0.85rem;
    height: 0.85rem;
    fill: #a86a00;
    opacity: 1;
  }

  .asset-card__star-count {
    line-height: 1;
  }

  @media (min-width: 760px) {
    .asset-card {
      grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
