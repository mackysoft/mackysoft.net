---
type Props = {
  title: string;
};

const { title } = Astro.props as Props;
const fallbackTwitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}`;
---

<section class="article-share" aria-labelledby="article-share-title" data-article-share data-share-title={title}>
  <h2 id="article-share-title">シェア</h2>

  <div class="button-row article-share__actions">
    <div class="article-share__action">
      <button type="button" class="button-link article-share__button" data-share-copy aria-label="コピーリンク">
        <svg class="article-share__icon article-share__icon--stroke" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="8.25" y="7.25" width="9.5" height="11.5" rx="2.25" />
          <path d="M6.75 15.25H6A2.75 2.75 0 0 1 3.25 12.5V6A2.75 2.75 0 0 1 6 3.25h6.5A2.75 2.75 0 0 1 15.25 6v.75" />
        </svg>
        <span class="visually-hidden">コピーリンク</span>
      </button>
      <span class="article-share__bubble" role="status" aria-live="polite" data-share-status hidden></span>
    </div>
    <button type="button" class="button-link article-share__button" data-share-native hidden aria-label="ネイティブシェア">
      <svg class="article-share__icon article-share__icon--stroke" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <circle cx="7" cy="12" r="2" />
        <circle cx="17" cy="6.5" r="2" />
        <circle cx="17" cy="17.5" r="2" />
        <path d="M8.8 11.05 15.2 7.45" />
        <path d="M8.8 12.95 15.2 16.55" />
      </svg>
      <span class="visually-hidden">ネイティブシェア</span>
    </button>
    <a
      href={fallbackTwitterHref}
      target="_blank"
      rel="noreferrer"
      class="button-link"
      data-share-twitter
      aria-label="Twitter"
    >
      <svg class="article-share__icon article-share__icon--twitter" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M18.244 3H21.5l-7.11 8.126L22.75 21h-6.548l-5.127-6.592L5.305 21H2.047l7.605-8.692L1.625 3H8.34l4.619 6.116L18.244 3Zm-1.141 16.05h1.804L7.36 4.848H5.424L17.103 19.05Z"
        />
      </svg>
      <span class="visually-hidden">Twitter</span>
    </a>
  </div>
</section>

<script is:inline>
  for (const root of document.querySelectorAll("[data-article-share]")) {
    if (!(root instanceof HTMLElement) || root.dataset.shareReady === "true") {
      continue;
    }

    root.dataset.shareReady = "true";

    const title = root.dataset.shareTitle ?? "";
    const currentUrl = window.location.href;
    const copyButton = root.querySelector("[data-share-copy]");
    const nativeShareButton = root.querySelector("[data-share-native]");
    const twitterLink = root.querySelector("[data-share-twitter]");
    const status = root.querySelector("[data-share-status]");
    let statusTimer = 0;

    if (!(copyButton instanceof HTMLButtonElement)) {
      continue;
    }

    const setStatus = (message) => {
      if (status instanceof HTMLElement) {
        status.textContent = message;
        status.hidden = false;
        window.clearTimeout(statusTimer);
        statusTimer = window.setTimeout(() => {
          status.hidden = true;
        }, 1800);
      }
    };

    if (twitterLink instanceof HTMLAnchorElement) {
      const twitterUrl = new URL("https://twitter.com/intent/tweet");
      twitterUrl.searchParams.set("text", title);
      twitterUrl.searchParams.set("url", currentUrl);
      twitterLink.href = twitterUrl.toString();
    }

    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(currentUrl);
        setStatus("リンクをコピーしました");
      } catch {
        setStatus("コピーに失敗しました");
      }
    });

    if (typeof navigator.share === "function" && nativeShareButton instanceof HTMLButtonElement) {
      nativeShareButton.hidden = false;
      nativeShareButton.addEventListener("click", async () => {
        try {
          await navigator.share({ title, url: currentUrl });
        } catch (error) {
          if (error instanceof DOMException && error.name === "AbortError") {
            return;
          }
        }
      });
    }
  }
</script>

<style>
  .article-share {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .article-share h2 {
    margin: 0;
    font-size: 1rem;
  }

  .article-share__actions {
    align-items: center;
  }

  .article-share__action {
    position: relative;
    display: inline-flex;
  }

  .article-share__button {
    appearance: none;
    cursor: pointer;
    font: inherit;
  }

  .article-share__actions :global(.button-link) {
    width: 3.5rem;
    height: 3.5rem;
    padding: 0;
    border-radius: 50%;
  }

  .article-share__icon {
    display: block;
    width: 1.7rem;
    height: 1.7rem;
    fill: currentColor;
  }

  .article-share__icon--stroke {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .article-share__icon--twitter {
    width: 1.45rem;
    height: 1.45rem;
  }

  .article-share__bubble {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.7rem);
    z-index: 1;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgba(30, 27, 24, 0.94);
    color: #f5efe2;
    font-size: 0.78rem;
    line-height: 1;
    white-space: nowrap;
    transform: translateX(-50%);
    box-shadow: 0 0.7rem 1.5rem rgba(30, 27, 24, 0.16);
    pointer-events: none;
  }

  .article-share__bubble::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    width: 0.6rem;
    height: 0.6rem;
    background: rgba(30, 27, 24, 0.94);
    transform: translate(-50%, -50%) rotate(45deg);
  }
</style>
