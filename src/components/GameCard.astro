---
import { Image } from "astro:assets";

import { getUiText } from "../lib/ui-text";
import { defaultLocale, type SiteLocale } from "../lib/i18n";
import GameStatusBadge from "./GameStatusBadge.astro";
import { formatContentDate } from "../lib/content-date";
import { getGamePlatformLabel } from "../lib/game-presentation";
import type { LocalizedGameEntry } from "../lib/game-repository";

type Props = {
  game: LocalizedGameEntry;
  layout?: "horizontal" | "compact";
  locale?: SiteLocale;
};

const { game, layout = "horizontal", locale = "ja" } = Astro.props as Props;
const href = game.href;
const publishedAt = game.data.publishedAt;
const platforms = game.data.platforms;
const showDescription = layout === "horizontal";
const publishedAtLabel = publishedAt ? formatContentDate(publishedAt, locale) : null;
const coverSizes = layout === "compact" ? "(max-width: 720px) 100vw, 20rem" : "(max-width: 720px) 100vw, 28rem";
const uiText = getUiText(locale);
---

<article class:list={["game-card", "activity-card", layout === "compact" && "activity-card--compact", `game-card--${layout}`]}>
  <a href={href} class="activity-card__link-layer" aria-label={game.data.title}></a>
  <div class="game-card__cover activity-card__cover">
    <Image src={game.data.cover} alt={game.data.coverAlt} widths={[480]} sizes={coverSizes} />
  </div>
  <div class="game-card__body activity-card__body">
    <h3 class="activity-card__title">{game.data.title}</h3>
    {showDescription && (
      <div class="game-card__copy">
        <p class="game-card__description">{game.data.description}</p>
      </div>
    )}
    <div class="game-card__footer">
      {publishedAtLabel && (
        <p class="game-card__meta activity-card__meta">
          <span class="game-card__meta-date">
            <span class="game-card__meta-label">{uiText.game.publishedAt}</span>
            <span>{publishedAtLabel}</span>
          </span>
        </p>
      )}
      <div class="game-card__metrics">
        <GameStatusBadge status={game.data.status} size="card" locale={locale} />
        {game.isFallback && locale !== defaultLocale && <p class="activity-card__badge">{uiText.common.japaneseOnlyBadge}</p>}
        {platforms.map((platform) => (
          <p class="game-card__platform">{getGamePlatformLabel(platform, locale)}</p>
        ))}
      </div>
    </div>
  </div>
</article>

<style>
  .game-card--horizontal {
    gap: 1rem;
    padding: 1.25rem;
  }

  .game-card__cover {
    aspect-ratio: 1200 / 630;
  }

  .game-card__cover :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-card__body {
    gap: 0.85rem;
  }

  .game-card__copy {
    min-height: 0;
  }

  .game-card__platform,
  .game-card__description,
  .game-card__meta {
    margin: 0;
  }

  .game-card__description {
    color: var(--muted-color);
  }

  .game-card__meta-date {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .game-card__footer {
    display: grid;
    gap: 0.55rem;
    margin-top: auto;
  }

  .game-card__meta {
    font-size: 0.92rem;
  }

  .game-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .game-card__platform {
    width: fit-content;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--surface-soft-border-color);
    border-radius: 999px;
    background: var(--surface-soft-color);
    color: var(--muted-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .game-card__date {
    color: var(--muted-color);
    background: var(--surface-raised-strong-color);
  }

  .game-card h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .game-card__description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .game-card--compact {
    gap: 0.75rem;
  }

  .game-card--compact .game-card__body {
    gap: 0.4rem;
  }

  .game-card--compact h3 {
    font-size: clamp(0.96rem, 0.9rem + 0.28vw, 1.08rem);
    line-height: 1.32;
    -webkit-line-clamp: 2;
  }

  .game-card--compact .game-card__description {
    font-size: 0.92rem;
    -webkit-line-clamp: 2;
  }

  .game-card--compact .game-card__meta {
    font-size: 0.84rem;
  }

  .game-card--compact .game-card__metrics {
    gap: 0.35rem;
  }

  .game-card--compact .game-card__platform {
    padding: 0.3rem 0.55rem;
    font-size: 0.76rem;
  }

  @media (min-width: 760px) {
    .game-card--horizontal {
      grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
