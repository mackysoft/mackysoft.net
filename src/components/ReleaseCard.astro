---
import { Image } from "astro:assets";

import type { ReleaseActivity } from "../lib/articles";
import { formatDate } from "../lib/articles";

type Props = {
  release: ReleaseActivity;
};

const { release } = Astro.props;
const repoName = release.repo.split("/").at(-1) ?? release.repo;
const showReleaseName = release.name !== release.version;
const stargazerCount = new Intl.NumberFormat("en-US").format(release.stargazerCount);
---

<article class="release-card">
  <a href={release.url} class="release-card__cover-link" target="_blank" rel="noreferrer">
    <Image src={release.coverUrl} alt={release.coverAlt} width={1200} height={630} widths={[480]} sizes="(max-width: 720px) 100vw, 20rem" />
  </a>
  <div class="release-card__body">
    <h3>
      <a href={release.url} target="_blank" rel="noreferrer">{repoName}</a>
    </h3>
    {showReleaseName && <p class="release-card__name">{release.name}</p>}
    <div class="release-card__footer">
      <p class="release-card__meta">
        <span>{formatDate(new Date(release.publishedAt))}</span>
        <span>{release.source}</span>
      </p>
      <div class="release-card__metrics">
        <p class="release-card__version">{release.version}</p>
        <span class="release-card__stars" aria-label={`GitHub stars ${stargazerCount}`}>
          <svg class="release-card__star-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3.25 14.703 8.728l6.047.879-4.375 4.265 1.033 6.022L12 17.051l-5.408 2.843 1.033-6.022-4.375-4.265 6.047-.879L12 3.25Z" />
          </svg>
          <span class="release-card__star-count">{stargazerCount}</span>
        </span>
      </div>
    </div>
  </div>
</article>

<style>
  .release-card {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 0.75rem;
    min-height: 19.75rem;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 1.25rem;
    background: var(--surface-color);
    overflow: hidden;
  }

  .release-card__cover-link {
    display: block;
    overflow: hidden;
    border-radius: 0.9rem;
    aspect-ratio: 1200 / 630;
    background: var(--surface-strong-color);
  }

  .release-card__cover-link :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .release-card__body {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: 0.4rem;
    min-height: 0;
  }

  .release-card__name,
  .release-card__meta,
  .release-card__version,
  .release-card__stars {
    margin: 0;
  }

  .release-card h3 {
    margin: 0;
    font-size: clamp(0.96rem, 0.9rem + 0.28vw, 1.08rem);
    line-height: 1.32;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .release-card h3 a {
    color: var(--text-color);
    text-decoration: none;
  }

  .release-card__name {
    color: var(--muted-color);
    font-size: 0.92rem;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .release-card__footer {
    display: grid;
    gap: 0.55rem;
    align-content: end;
    margin-top: auto;
  }

  .release-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .release-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: var(--muted-color);
    font-size: 0.84rem;
  }

  .release-card__version {
    width: fit-content;
    padding: 0.3rem 0.55rem;
    border-radius: 999px;
    background: rgba(14, 107, 99, 0.1);
    color: var(--accent-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .release-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    padding: 0.3rem 0.55rem;
    border: 1px solid rgba(14, 107, 99, 0.16);
    border-radius: 999px;
    color: var(--text-color);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .release-card__star-icon {
    flex: none;
    width: 0.85rem;
    height: 0.85rem;
    fill: #a86a00;
    opacity: 1;
  }

  .release-card__star-count {
    line-height: 1;
  }
</style>
