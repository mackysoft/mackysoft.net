---
import { Image } from "astro:assets";

import { getUiText } from "../lib/ui-text";
import type { SiteLocale } from "../lib/i18n";
import { formatContentDate } from "../lib/content-date";
import { formatReleaseStargazerCount, getReleaseRepoName, type ReleaseActivity } from "../lib/releases";
import { releaseCoverWidths, resolveReleaseCoverImageUrl } from "../features/releases/cover-image";

type Props = {
  release: ReleaseActivity;
  locale?: SiteLocale;
};

const { release, locale = "ja" } = Astro.props as Props;
const repoName = getReleaseRepoName(release.repo);
const stargazerCount = formatReleaseStargazerCount(release.stargazerCount, locale);
const uiText = getUiText(locale);
const coverSrc = resolveReleaseCoverImageUrl(release.coverUrl, Astro.site ?? Astro.url);
---

<article class="release-card activity-card activity-card--compact">
  <a
    href={release.url}
    class="activity-card__link-layer"
    aria-label={repoName}
    target="_blank"
    rel="noreferrer"
    data-analytics-event="external_link_click"
    data-analytics-label={repoName}
    data-analytics-location="release-card"
  ></a>
  <div class="release-card__cover activity-card__cover" data-cover-state="ready">
    <Image
      src={coverSrc}
      alt={release.coverAlt}
      widths={releaseCoverWidths}
      sizes="(max-width: 720px) 100vw, 20rem"
      inferSize
      loading="lazy"
      decoding="async"
      onerror="this.parentElement?.setAttribute('data-cover-state', 'error')"
    />
    <div class="release-card__cover-fallback" aria-hidden="true">
      <span class="release-card__cover-kicker">GitHub</span>
      <strong class="release-card__cover-title">{repoName}</strong>
    </div>
  </div>
  <div class="release-card__body activity-card__body">
    <h3 class="activity-card__title">{repoName}</h3>
    <div class="release-card__copy">
      {release.description && <p class="release-card__description">{release.description}</p>}
    </div>
    <div class="release-card__footer">
      <p class="release-card__meta activity-card__meta">
        <span class="release-card__meta-date">
          <span class="release-card__meta-label">{uiText.release.latestReleaseDate}</span>
          <span>{formatContentDate(new Date(release.publishedAt), locale)}</span>
        </span>
      </p>
      <div class="release-card__metrics">
        {release.license && <p class="release-card__license pill pill--compact">{release.license}</p>}
        <p class="release-card__version pill pill--compact pill--accent">{release.version}</p>
        <span class="release-card__stars pill pill--compact pill--accent-outline" aria-label={`GitHub stars ${stargazerCount}`}>
          <svg class="release-card__star-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3.25 14.703 8.728l6.047.879-4.375 4.265 1.033 6.022L12 17.051l-5.408 2.843 1.033-6.022-4.375-4.265 6.047-.879L12 3.25Z" />
          </svg>
          <span class="release-card__star-count">{stargazerCount}</span>
        </span>
      </div>
    </div>
  </div>
</article>

<style>
  .release-card__cover {
    aspect-ratio: 1200 / 630;
    position: relative;
    overflow: hidden;
  }

  .release-card__cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .release-card__cover-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: end;
    gap: 0.35rem;
    padding: 0.85rem;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent-color) 20%, transparent) 0, transparent 34%),
      linear-gradient(160deg, color-mix(in srgb, var(--surface-soft-color) 92%, white) 0%, var(--surface-color) 100%);
    color: var(--text-color);
  }

  .release-card__cover[data-cover-state="ready"] .release-card__cover-fallback {
    display: none;
  }

  .release-card__cover[data-cover-state="error"] img {
    display: none;
  }

  .release-card__cover-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-color);
  }

  .release-card__cover-title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: clamp(0.95rem, 0.88rem + 0.3vw, 1.08rem);
    line-height: 1.2;
  }

  .release-card__body {
    gap: 0.4rem;
  }

  .release-card__copy,
  .release-card__description,
  .release-card__meta,
  .release-card__meta-label,
  .release-card__license,
  .release-card__version,
  .release-card__stars {
    margin: 0;
  }

  .release-card h3 {
    margin: 0;
    font-size: clamp(0.96rem, 0.9rem + 0.28vw, 1.08rem);
    line-height: 1.32;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .release-card__copy {
    min-height: 0;
  }

  .release-card__meta-date {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .release-card__description {
    color: var(--muted-color);
    font-size: 0.92rem;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .release-card__footer {
    display: grid;
    gap: 0.55rem;
    align-content: end;
    margin-top: auto;
  }

  .release-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .release-card__meta {
    font-size: 0.84rem;
  }

  .release-card__version {
    --pill-text-color: var(--accent-color);
  }

  .release-card__license {
    margin: 0;
  }

  .release-card__stars {
    margin: 0;
  }

  .release-card__star-icon {
    flex: none;
    width: 0.85rem;
    height: 0.85rem;
    fill: var(--warm-accent-color);
    opacity: 1;
  }

  .release-card__star-count {
    line-height: 1;
  }

  @media (max-width: 759px) {
    .release-card {
      padding: 1rem;
    }

    .release-card__description {
      display: none;
    }
  }
</style>
