---
import { localizePath, type SiteLocale } from "../../lib/i18n";
import { getProfileAvatar } from "../profile/avatar";
import { getProfileContent } from "../profile/content";

type Props = {
  locale: SiteLocale;
  primaryCtaLabel: string;
  contactCtaLabel: string;
};

const { locale, primaryCtaLabel, contactCtaLabel } = Astro.props as Props;
const profile = getProfileContent(locale);
const avatar = getProfileAvatar(locale);
---

<section class="content-panel home-hero" data-home-hero>
  <img
    src={avatar.src.src}
    alt={avatar.alt}
    class="home-hero__avatar"
    loading="eager"
    decoding="async"
  />
  <div class="home-hero__copy">
    <p class="home-hero__name">{profile.home.name}</p>
    <p class="home-hero__summary">{profile.home.summary}</p>
  </div>
  <div class="button-row home-hero__actions">
    <a
      href={localizePath("/about/", locale)}
      class="button-link home-hero__cta"
      data-analytics-event="project_cta_click"
      data-analytics-label={primaryCtaLabel}
      data-analytics-location="home-hero"
    >
      {primaryCtaLabel}
    </a>
    <a
      href={localizePath("/contact/", locale)}
      class="button-link home-hero__cta home-hero__cta--secondary"
      data-analytics-event="project_cta_click"
      data-analytics-label={contactCtaLabel}
      data-analytics-location="home-hero"
    >
      {contactCtaLabel}
    </a>
  </div>
</section>

<style>
  .home-hero {
    display: grid;
    gap: 0.9rem;
    align-items: center;
    padding: 1.2rem 1.3rem;
  }

  .home-hero__avatar {
    display: block;
    width: clamp(3.5rem, 10vw, 4.5rem);
    height: clamp(3.5rem, 10vw, 4.5rem);
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: var(--surface-raised-strong-color);
    object-fit: cover;
  }

  .home-hero__copy {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .home-hero__name,
  .home-hero__summary {
    margin: 0;
  }

  .home-hero__name {
    font-size: clamp(1.18rem, 1.05rem + 0.65vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .home-hero__summary {
    color: var(--muted-color);
  }

  .home-hero__actions {
    justify-self: start;
  }

  .home-hero__cta {
    min-width: 0;
  }

  .home-hero__cta:not(.home-hero__cta--secondary) {
    border-color: var(--action-button-border-color);
    background: var(--action-button-bg-color);
    color: var(--action-button-text-color);
  }

  .home-hero__cta:not(.home-hero__cta--secondary):hover,
  .home-hero__cta:not(.home-hero__cta--secondary):focus-visible {
    border-color: var(--action-button-border-color);
    background: var(--action-button-hover-bg-color);
    color: var(--action-button-text-color);
  }

  @media (max-width: 719px) {
    .home-hero__actions {
      width: 100%;
    }

    .home-hero__actions :global(.button-link) {
      flex: 1 1 auto;
    }
  }

  @media (min-width: 720px) {
    .home-hero {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 1rem 1.3rem;
    }

    .home-hero__actions {
      justify-self: end;
      justify-content: end;
    }
  }
</style>
