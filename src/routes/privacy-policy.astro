---
import PageLead from "../components/PageLead.astro";
import PageHeader from "../components/PageHeader.astro";
import { getPrivacyPolicyContent } from "../features/privacy-policy/content";
import { createAlternateLocaleLinks, getPathLocale, localizePath, type SiteLocale } from "../lib/i18n";
import { isExternalHttpHref } from "../lib/safe-href";
import SiteLayout from "../layouts/SiteLayout.astro";

type Props = {
  locale?: SiteLocale;
};

const { locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const content = getPrivacyPolicyContent(locale);

function resolvePolicyLinkHref(href: string) {
  if (href.startsWith("/")) {
    return localizePath(href, locale);
  }

  return href;
}
---

<SiteLayout
  title={content.title}
  description={content.description}
  locale={locale}
  canonicalPath={localizePath("/privacy-policy/", locale)}
  alternateLocales={createAlternateLocaleLinks("/privacy-policy/")}
>
  <PageHeader title={content.hero.title} eyebrow={content.hero.eyebrow} />

  <PageLead panel>
    {content.lead.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </PageLead>

  <div class="privacy-policy-sections">
    {content.sections.map((section) => (
      <section class="content-panel privacy-policy-section">
        <h2>{section.heading}</h2>
        <div class="privacy-policy-section__body">
          {section.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          {section.items && (
            <ul class="privacy-policy-section__list">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
          {section.links && (
            <ul class="privacy-policy-section__links">
              {section.links.map((link) => (
                <li>
                  <a
                    href={resolvePolicyLinkHref(link.href)}
                    target={isExternalHttpHref(link.href) ? "_blank" : undefined}
                    rel={isExternalHttpHref(link.href) ? "noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </section>
    ))}
  </div>
</SiteLayout>

<style>
  .privacy-policy-sections {
    display: grid;
    gap: 1rem;
  }

  .privacy-policy-section {
    display: grid;
    gap: 0.85rem;
  }

  .privacy-policy-section h2,
  .privacy-policy-section p,
  .privacy-policy-section ul {
    margin: 0;
  }

  .privacy-policy-section__body {
    display: grid;
    gap: 0.75rem;
  }

  .privacy-policy-section__list,
  .privacy-policy-section__links {
    display: grid;
    gap: 0.6rem;
    padding-left: 1.2rem;
  }
</style>
