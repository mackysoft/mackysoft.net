---
import { render } from "astro:content";

import LocalizedHtmlLinks from "../components/LocalizedHtmlLinks.astro";
import PageHeader from "../components/PageHeader.astro";
import { formatBreadcrumb } from "../lib/breadcrumb";
import { createAlternateLocaleLinks, getPathLocale, localizePath, type SiteLocale } from "../lib/i18n";
import { resolveLocalizedPageBySlug } from "../lib/pages";
import { getUiText } from "../lib/ui-text";
import SiteLayout from "../layouts/SiteLayout.astro";

type Props = {
  locale?: SiteLocale;
};

const { locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const uiText = getUiText(locale);
const page = await resolveLocalizedPageBySlug("privacy-policy", locale);

if (!page) {
  throw new Error("Unknown page slug: privacy-policy");
}

const { Content } = await render(page.entry as never);
---

<SiteLayout
  title={page.data.title}
  description={page.data.description}
  locale={locale}
  contentLocale={page.contentLocale}
  isFallback={page.isFallback}
  canonicalPath={localizePath("/privacy-policy/", locale)}
  alternateLocales={createAlternateLocaleLinks("/privacy-policy/", page.availableLocales)}
>
  <PageHeader title={page.data.title} eyebrow={formatBreadcrumb(uiText.common.home, page.data.title)} />

  <section class="content-panel prose">
    <LocalizedHtmlLinks locale={locale}>
      <Content />
    </LocalizedHtmlLinks>
  </section>
</SiteLayout>
