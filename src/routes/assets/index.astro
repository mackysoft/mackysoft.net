---
import AssetCard from "../../components/AssetCard.astro";
import PageLead from "../../components/PageLead.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getAssetsPageContent } from "../../features/assets/content";
import { getUiText } from "../../lib/ui-text";
import { formatBreadcrumb } from "../../lib/breadcrumb";
import { createAlternateLocaleLinks, getPathLocale, localizePath, type SiteLocale } from "../../lib/i18n";
import { getReleaseActivities } from "../../lib/releases";
import { getExternalLink } from "../../lib/site";
import SiteLayout from "../../layouts/SiteLayout.astro";

type Props = {
  locale?: SiteLocale;
};

const { locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const uiText = getUiText(locale);
const releases = getReleaseActivities();
const pageContent = getAssetsPageContent(locale, uiText.common.assets);
const sponsorLink = getExternalLink("githubSponsors");
---

<SiteLayout
  title={pageContent.title}
  description={pageContent.description}
  locale={locale}
  canonicalPath={localizePath("/assets/", locale)}
  alternateLocales={createAlternateLocaleLinks("/assets/")}
>
  <PageHeader title={uiText.common.assets} eyebrow={formatBreadcrumb(uiText.common.home, uiText.common.assets)} />

  <section class="content-panel sponsor-callout" aria-label={pageContent.support.ariaLabel}>
    <p class="sponsor-callout__body">{pageContent.support.body}</p>
    <a
      href={sponsorLink.href}
      class="button-link sponsor-callout__action"
      target="_blank"
      rel="noreferrer"
      data-analytics-event="external_link_click"
      data-analytics-label={sponsorLink.label}
      data-analytics-location="assets-support"
    >
      <svg class="sponsor-callout__action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 20.25 10.55 18.94C5.4 14.28 2 11.2 2 7.42 2 4.34 4.42 2 7.5 2c1.74 0 3.41.81 4.5 2.09A5.94 5.94 0 0 1 16.5 2C19.58 2 22 4.34 22 7.42c0 3.78-3.4 6.86-8.55 11.53L12 20.25Z" />
      </svg>
      <span>{pageContent.support.ctaLabel}</span>
    </a>
  </section>

  <PageLead class="assets-list">
    {releases.map((release) => (
      <AssetCard release={release} locale={locale} />
    ))}
  </PageLead>
</SiteLayout>

<style>
  .sponsor-callout {
    --sponsor-accent-color: #cf4f92;
    --sponsor-accent-surface-color: color-mix(in srgb, var(--sponsor-accent-color) 8%, var(--surface-color));
    --sponsor-accent-border-color: color-mix(in srgb, var(--sponsor-accent-color) 22%, var(--border-color));
    --sponsor-accent-button-bg-color: color-mix(in srgb, var(--sponsor-accent-color) 10%, var(--surface-raised-color));
    --sponsor-accent-button-border-color: color-mix(in srgb, var(--sponsor-accent-color) 28%, transparent);
    --sponsor-accent-button-hover-bg-color: color-mix(in srgb, var(--sponsor-accent-color) 16%, var(--surface-raised-strong-color));
    display: grid;
    gap: 0.85rem;
    align-items: center;
    border-color: var(--sponsor-accent-border-color);
    background: var(--sponsor-accent-surface-color);
  }

  .sponsor-callout__body {
    margin: 0;
    color: var(--muted-color);
  }

  .sponsor-callout__action {
    gap: 0.45rem;
    justify-self: start;
    border-color: var(--sponsor-accent-button-border-color);
    background: var(--sponsor-accent-button-bg-color);
    color: var(--text-color);
  }

  .sponsor-callout__action-icon {
    width: 0.95rem;
    height: 0.95rem;
    fill: var(--sponsor-accent-color);
    flex: none;
  }

  .sponsor-callout__action:hover,
  .sponsor-callout__action:focus-visible {
    border-color: color-mix(in srgb, var(--sponsor-accent-color) 44%, transparent);
    background: var(--sponsor-accent-button-hover-bg-color);
  }

  .assets-list {
    grid-template-columns: 1fr;
  }

  @media (min-width: 760px) {
    .sponsor-callout {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1.25rem;
    }
  }
</style>
