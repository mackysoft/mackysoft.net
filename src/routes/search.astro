---
import PageHeader from "../components/PageHeader.astro";
import SearchPanel from "../components/search/SearchPanel.astro";
import { formatBreadcrumb } from "../lib/breadcrumb";
import { createAlternateLocaleLinks, getPathLocale, localizePath, type SiteLocale } from "../lib/i18n";
import { getUiText } from "../lib/ui-text";
import SiteLayout from "../layouts/SiteLayout.astro";

type Props = {
  locale?: SiteLocale;
};

const { locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const uiText = getUiText(locale);
const searchPath = localizePath("/search/", locale);
const initialQuery = Astro.url.searchParams.get("q") ?? "";
const analyticsPageLocation = new URL(searchPath, Astro.url).toString();
---

<SiteLayout
  title={uiText.common.search}
  description={uiText.search.pageDescription}
  locale={locale}
  canonicalPath={searchPath}
  alternateLocales={createAlternateLocaleLinks("/search/")}
  analyticsPageLocation={analyticsPageLocation}
>
  <PageHeader title={uiText.common.search} eyebrow={formatBreadcrumb(uiText.breadcrumb.home, uiText.breadcrumb.search)} />

  <SearchPanel locale={locale} mode="page" searchPath={searchPath} initialQuery={initialQuery} />
</SiteLayout>
