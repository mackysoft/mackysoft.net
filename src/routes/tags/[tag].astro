---
import ArticleCard from "../../components/ArticleCard.astro";
import PageLead from "../../components/PageLead.astro";
import PageHeader from "../../components/PageHeader.astro";
import { formatArticleCount, getUiText } from "../../lib/copy";
import { getLocalArticles, toLocalArticleItem } from "../../lib/articles";
import { getPathLocale, localizePath, type SiteLocale } from "../../lib/i18n";
import { formatPageBreadcrumb } from "../../lib/page-header";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const articles = await getLocalArticles();
  const tags = new Set(articles.flatMap((article) => article.data.tags));

  return Array.from(tags).sort((left, right) => left.localeCompare(right, "ja")).map((tag) => ({
    params: { tag },
    props: {
      tag,
      articleEntries: articles.filter((article) => article.data.tags.includes(tag)),
    },
  }));
}

type Props = {
  tag: string;
  articleEntries: Awaited<ReturnType<typeof getLocalArticles>>;
  locale?: SiteLocale;
};

const { tag, articleEntries, locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const uiText = getUiText(locale);
const articles = await Promise.all(articleEntries.map((article) => toLocalArticleItem(article, locale)));
---

<SiteLayout
  title={`${uiText.common.tag}: ${tag}`}
  description={locale === "en" ? `Articles tagged with ${tag}.` : `${tag} に紐づく記事一覧です。`}
  locale={locale}
  canonicalPath={localizePath(`/tags/${tag}/`, locale)}
  alternateLocales={[
    { locale: "ja", path: `/tags/${tag}/` },
    { locale: "en", path: `/en/tags/${tag}/` },
  ]}
>
  <PageHeader title={tag} eyebrow={formatPageBreadcrumb(uiText.common.home, uiText.common.articles, uiText.common.tag)} />

  <PageLead summary={formatArticleCount(articles.length, locale)}>
    {articles.map((article) => (
      <ArticleCard article={article} locale={locale} />
    ))}
  </PageLead>
</SiteLayout>
