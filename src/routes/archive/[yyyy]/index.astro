---
import ArticleCard from "../../../components/ArticleCard.astro";
import PageLead from "../../../components/PageLead.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { getArticlesArchiveYearPageMeta } from "../../../features/articles/page-meta";
import { formatArticleCount, getUiText } from "../../../lib/copy";
import { getArticleYear } from "../../../lib/article-dates";
import { getLocalArticles, toLocalArticleItem } from "../../../lib/articles";
import { createAlternateLocaleLinks, getPathLocale, localizePath, type SiteLocale } from "../../../lib/i18n";
import { formatPageBreadcrumb } from "../../../lib/page-header";
import SiteLayout from "../../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const articles = await getLocalArticles();
  const years = new Set(articles.map((article) => getArticleYear(article.data.publishedAt)));

  return Array.from(years).sort().map((year) => ({
    params: { yyyy: year },
    props: {
      year,
      articleEntries: articles.filter((article) => getArticleYear(article.data.publishedAt) === year),
    },
  }));
}

type Props = {
  year: string;
  articleEntries: Awaited<ReturnType<typeof getLocalArticles>>;
  locale?: SiteLocale;
};

const { year, articleEntries, locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const uiText = getUiText(locale);
const articles = await Promise.all(articleEntries.map((article) => toLocalArticleItem(article, locale)));
const pageMeta = getArticlesArchiveYearPageMeta(locale, year, {
  archive: uiText.common.archive,
});
---

<SiteLayout
  title={pageMeta.title}
  description={pageMeta.description}
  locale={locale}
  canonicalPath={localizePath(`/archive/${year}/`, locale)}
  alternateLocales={createAlternateLocaleLinks(`/archive/${year}/`)}
>
  <PageHeader title={year} eyebrow={formatPageBreadcrumb(uiText.common.home, uiText.common.articles, uiText.common.archive)} />

  <PageLead summary={formatArticleCount(articles.length, locale)}>
    {articles.map((article) => (
      <ArticleCard article={article} locale={locale} />
    ))}
  </PageLead>
</SiteLayout>
