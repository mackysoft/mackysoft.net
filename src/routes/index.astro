---
import ArticleCard from "../components/ArticleCard.astro";
import GameCard from "../components/GameCard.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import HomeActivitySection from "../features/home/HomeActivitySection.astro";
import { getHomePageContent } from "../features/home/content";
import HomeHero from "../features/home/HomeHero.astro";
import { getArticleItems } from "../lib/articles";
import { getLocalizedGames } from "../lib/game-repository";
import { createAlternateLocaleLinks, defaultLocale, getPathLocale, localizePath, type SiteLocale } from "../lib/i18n";
import { getLatestReleases } from "../lib/releases";
import SiteLayout from "../layouts/SiteLayout.astro";

type Props = {
  locale?: SiteLocale;
};

const { locale: localeProp } = Astro.props as Props;
const locale = localeProp ?? getPathLocale(Astro.url.pathname);
const content = getHomePageContent(locale);
const latestArticles = (await getArticleItems(locale)).slice(0, 3);
const latestReleases = getLatestReleases();
const homeGames = (await getLocalizedGames(locale)).filter((game): game is NonNullable<typeof game> => game !== null).slice(0, 3);
const localizedHomePath = localizePath("/", locale);
---

<SiteLayout
  locale={locale}
  canonicalPath={localizedHomePath}
  alternateLocales={createAlternateLocaleLinks("/")}
  enableLocaleRedirectOnRoot={locale === defaultLocale}
>
  <h1 class="visually-hidden">{content.homeHeading}</h1>
  <HomeHero locale={locale} primaryCtaLabel={content.heroPrimaryCta} contactCtaLabel={content.heroContactCta} />

  <HomeActivitySection
    eyebrow={content.latestArticlesEyebrow}
    heading={content.latestArticlesHeading}
    ctaHref={localizePath("/articles/", locale)}
    ctaLabel={content.latestArticlesCta}
    analyticsLocation="home-latest-articles"
    gridClass="latest-articles-grid"
  >
    {latestArticles.map((article) => (
      <ArticleCard article={article} layout="vertical" locale={locale} />
    ))}
  </HomeActivitySection>

  {latestReleases.length > 0 && (
    <HomeActivitySection
      eyebrow={content.latestReleasesEyebrow}
      heading={content.latestReleasesHeading}
      ctaHref={localizePath("/assets/", locale)}
      ctaLabel={content.latestReleasesCta}
      analyticsLocation="home-latest-releases"
      gridClass="latest-releases-grid"
    >
      {latestReleases.map((release) => (
        <ReleaseCard release={release} locale={locale} />
      ))}
    </HomeActivitySection>
  )}

  {homeGames.length > 0 && (
    <HomeActivitySection
      eyebrow={content.gamesEyebrow}
      heading={content.gamesHeading}
      ctaHref={localizePath("/games/", locale)}
      ctaLabel={content.gamesCta}
      analyticsLocation="home-games"
      gridClass="latest-games-grid"
    >
      {homeGames.map((game) => (
        <GameCard game={game} layout="compact" locale={locale} />
      ))}
    </HomeActivitySection>
  )}
</SiteLayout>
