{
  "name": "mackysoft.net",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.17.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:og-default && npm run generate:activity-cover-assets && astro build && node scripts/build-search-index.mjs && node scripts/build-static-redirects.mjs",
    "deploy:workers": "npm run deploy:workers:site && npm run deploy:workers:www-redirect",
    "deploy:workers:site": "wrangler deploy",
    "deploy:workers:www-redirect": "wrangler deploy -c wrangler.www-redirect.jsonc",
    "generate:favicon": "node scripts/generate-favicon.mjs",
    "generate:activity-cover-assets": "node scripts/generate-activity-cover-assets.mjs",
    "generate:og-default": "node scripts/generate-default-og.mjs",
    "preview": "astro preview",
    "preview:ci": "astro preview --host 127.0.0.1 --port 4322",
    "check": "npm run generate:activity-cover-assets && astro check",
    "new:article": "node scripts/create-article.mjs",
    "sync:migration-status": "node scripts/sync-migration-status.mjs",
    "sync:activity": "node scripts/sync-activity.mjs",
    "test:unit": "vitest run",
    "test:e2e:setup": "playwright install --with-deps chromium",
    "test:e2e:run": "playwright test",
    "test:e2e": "npm run build && npm run test:e2e:setup && npm run test:e2e:run",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.5.2",
    "astro": "^6.1.6",
    "cheerio": "^1.1.2",
    "pagefind": "^1.5.2",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "wrangler": "^4.82.1"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18"
  }
}
