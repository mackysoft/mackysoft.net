    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "astro": "^6.1.4",
    "cheerio": "^1.1.2",
    "typescript": "^5.9.3",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "vitest": "^4.1.3"
  }
}
