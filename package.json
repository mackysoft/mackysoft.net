{
  "name": "mackysoft.net",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.17.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:ci": "astro preview --host 127.0.0.1 --port 4322",
    "check": "astro check",
    "import:wordpress": "node scripts/import-wordpress.mjs",
    "sync:activity": "node scripts/sync-activity.mjs",
    "test:unit": "vitest run",
    "test:e2e:setup": "playwright install --with-deps chromium",
