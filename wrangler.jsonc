{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "site",
  "main": "./worker/index.mjs",
  "compatibility_date": "2026-04-14",
  "workers_dev": true,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/",
      "/_astro/*",
      "/about/",
      "/archive/*",
      "/articles/*",
      "/assets/*",
      "/contact/",
      "/en/*",
      "/feed.xml",
      "/games/*",
      "/llms.txt",
      "/og/*",
      "/pagefind/*",
      "/privacy-policy/",
      "/robots.txt",
      "/search/",
      "/sitemap.xml",
      "/tags/*"
    ]
  }
}
